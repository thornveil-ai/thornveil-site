---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const domains = [
  {
    title: 'Counter-UAS & Threat Detection',
    description: [
      'Thornveil develops thermal and visual drone detection systems using state-of-the-art deep learning architectures. Our detection models achieve benchmark-leading accuracy on thermal UAV datasets, operating at high resolution for real-time edge inference.',
      'Beyond detection, we build autonomous intercept planning systems that implement the full F2T2EA kill chain — from find to assess. These systems integrate natively with TAK and ATAK for seamless tactical common operating picture integration.',
      'Our counter-UAS work spans the full spectrum: passive detection via thermal imaging, active tracking with multi-sensor fusion, and autonomous engagement planning for interceptor platforms.',
    ],
    tags: ['Computer Vision', 'Object Detection', 'Edge Inference', 'TAK Integration', 'Thermal Imaging', 'Kill Chain Automation'],
    metrics: [
      { label: 'Detection mAP@50', value: '>80%' },
      { label: 'Inference Resolution', value: '1280px' },
      { label: 'Integration', value: 'TAK/ATAK Native' },
    ],
    icon: '<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    title: 'Autonomous Swarm Systems',
    description: [
      'We pioneered acoustic intra-swarm communication — enabling drone swarms to communicate and localize each other using only sound. No GPS, no RF. Each drone modulates its propeller RPM to encode data, cancels its own motor noise, and estimates relative position via microphone array direction-of-arrival.',
      'Our cooperative extended Kalman filter achieves sub-decimeter positioning accuracy with as few as four peers. The system supports both propeller-only communication (zero additional SWaP) and speaker-assisted wideband OFDM for higher data rates.',
      'The full stack includes adaptive modulation, TDMA MAC protocols, frequency-hopping spread spectrum security, and Reynolds flocking with formation control — all validated through comprehensive software-in-the-loop feasibility studies.',
    ],
    tags: ['Acoustic Comms', 'GPS-Denied Nav', 'Swarm Autonomy', 'FHSS', 'EKF', 'TDMA'],
    metrics: [
      { label: 'Positioning Accuracy', value: '<0.07m' },
      { label: 'Ranging Accuracy', value: '<0.5cm' },
      { label: 'DOA Resolution', value: '<0.04°' },
    ],
    icon: '<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 003.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0120.25 6v1.5m0 9V18A2.25 2.25 0 0118 20.25h-1.5m-9 0H6A2.25 2.25 0 013.75 18v-1.5M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    title: 'CBRN Sensor Fusion',
    description: [
      'Thornveil builds real-time chemical sensor fusion dashboards that aggregate data from JCAD, AP4C, ACADA, and LCD chemical detectors into a single tactical common operating picture. Our systems provide automated threat classification with multi-level alerting and MOPP recommendations.',
      'The dashboard features a 7-panel drag-and-resize tactical display including MapLibre-based mapping with MIL-STD-2525 markers, contamination zone modeling, threat heatmap overlays, and concentration timelines. Native TAK integration publishes JSON CoT events directly from the browser.',
      'Designed for austere environments, our systems run self-contained demo scenarios for training and evaluation, with seamless live-mode switching when backend sensor feeds are available.',
    ],
    tags: ['Sensor Fusion', 'Real-Time Processing', 'Chemical Defense', 'TAK', 'MIL-STD-2525', 'WebSocket'],
    metrics: [
      { label: 'Sensor Types', value: '4 (JCAD, AP4C, ACADA, LCD)' },
      { label: 'Alert Levels', value: 'CAUTION → IMMEDIATE' },
      { label: 'TAK Integration', value: 'Native CoT/NATS' },
    ],
    icon: '<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>',
  },
  {
    title: 'AI Decision Support & Secure LLM Systems',
    description: [
      'We build AI-powered digital staff officers that give military leaders instant, role-appropriate access to operational data. Our systems use tool-augmented LLMs to query live data sources — student records, training schedules, qualification tracking, calendars — and deliver synthesized briefs in seconds.',
      'Our classification-aware LLM routing systems enforce IL5 compliance at the query level, routing requests by sensitivity classification with 100% accuracy on adversarial test suites. Built on FIPS 140-3 compliant cryptography with zero CGO dependencies.',
      'Authentication supports both demo and production modes — from cookie-based role pickers for evaluation to CAC/PKI via X.509 client certificates for deployment on MCEN. Data backends are pluggable: JSON, SQLite, PostgreSQL, Excel, or SharePoint — same application code, different backends.',
    ],
    tags: ['LLM', 'FIPS 140-3', 'IL5', 'Zero Trust', 'CAC/PKI', 'Azure Gov'],
    metrics: [
      { label: 'Classification Accuracy', value: '100%' },
      { label: 'NIST 800-53 Controls', value: '44 implemented' },
      { label: 'Crypto Standard', value: 'FIPS 140-3' },
    ],
    icon: '<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>',
  },
];
---

<BaseLayout
  title="Capabilities | Thornveil"
  description="Counter-UAS, swarm intelligence, CBRN sensor fusion, and secure AI decision support. End-to-end defense technology from algorithm to edge deployment."
>
  <PageHero
    title="Capabilities"
    subtitle="End-to-end defense technology — from algorithm to edge deployment."
  />

  <!-- Domain sections -->
  {domains.map((domain, i) => (
    <section class={`section-padding relative ${i % 2 === 0 ? '' : 'bg-navy-dark/50'}`}>
      <div class="container-max mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">
          <!-- Main content -->
          <div class="lg:col-span-2">
            <div class="flex items-start gap-4 mb-6 reveal">
              <div class="w-14 h-14 rounded-lg bg-teal/10 border border-teal/20 flex items-center justify-center flex-shrink-0 text-teal-light">
                <Fragment set:html={domain.icon} />
              </div>
              <h2 class="text-2xl md:text-3xl font-bold tracking-tight pt-2">
                {domain.title}
              </h2>
            </div>

            <div class="space-y-4 reveal reveal-delay-1">
              {domain.description.map((p) => (
                <p class="text-white/50 leading-relaxed">{p}</p>
              ))}
            </div>

            <!-- Tags -->
            <div class="mt-8 flex flex-wrap gap-2 reveal reveal-delay-2">
              {domain.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>

          <!-- Metrics sidebar -->
          <div class="reveal reveal-delay-3">
            <div class="bg-white/[0.02] border border-white/5 rounded-lg p-8 space-y-6">
              <h3 class="text-xs font-semibold tracking-[0.3em] uppercase text-teal mb-6">Key Metrics</h3>
              {domain.metrics.map((metric) => (
                <div class="border-b border-white/5 pb-4 last:border-0 last:pb-0">
                  <div class="text-xs text-white/30 tracking-wider uppercase mb-1">{metric.label}</div>
                  <div class="text-lg font-semibold text-white/90">{metric.value}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- SBIR Experience -->
  <section class="section-padding relative bg-navy-dark">
    <div class="container-max mx-auto text-center">
      <p class="text-xs font-semibold tracking-[0.3em] uppercase text-teal mb-4 reveal">Government Experience</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight reveal reveal-delay-1">
        Proven SBIR Performance
      </h2>
      <p class="mt-6 text-white/50 max-w-2xl mx-auto leading-relaxed reveal reveal-delay-2">
        Thornveil has won competitive Phase I and Direct-to-Phase-II SBIR awards across multiple
        DoD components — including USSOCOM, SpaceWERX, and the Chemical and Biological Defense Program.
        Every proposal backed by working prototypes, not slide decks.
      </p>

      <div class="mt-12 flex flex-wrap justify-center gap-8 text-sm text-white/30 reveal reveal-delay-3">
        <span class="tracking-wider">NAICS 541511</span>
        <span class="text-white/10">|</span>
        <span class="tracking-wider">NAICS 541512</span>
        <span class="text-white/10">|</span>
        <span class="tracking-wider">Virginia LLC</span>
      </div>

      <div class="mt-12 reveal reveal-delay-4">
        <a href="/contact" class="btn-primary">
          Discuss a Partnership
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
