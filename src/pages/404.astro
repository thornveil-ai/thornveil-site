---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Thornveil">
  <section class="section-padding pt-32 md:pt-40 min-h-[60vh] flex items-center">
    <div class="container-max mx-auto text-center">
      <h1 class="text-fluid-3xl font-semibold tracking-tight reveal">Page not found</h1>
      <p class="text-base mt-4 reveal reveal-delay-1" style="color: var(--color-text-secondary);">
        The page you requested does not exist.
      </p>
      <div class="mt-8 reveal reveal-delay-2">
        <a href="/" class="btn-primary text-sm uppercase">
          Back to Home
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
