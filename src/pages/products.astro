---
import BaseLayout from '../layouts/BaseLayout.astro';

const agents = [
  {
    id: 'code-reviewer',
    name: 'Code Reviewer',
    subtitle: 'Senior Principal Security Engineer',
    description: 'Finds real bugs, security vulnerabilities, and performance bottlenecks. Produces structured JSON reviews with severity ratings, file:line locations, impact analysis, and concrete fix suggestions.',
    tools: 9,
    tags: ['Security', 'Bug Detection', 'Performance', 'Static Analysis'],
    output: 'Structured JSON with verdict, severity, file:line, impact, fix suggestion',
  },
  {
    id: 'security-auditor',
    name: 'Security Auditor',
    subtitle: 'Principal Application Security Engineer',
    description: 'Comprehensive code audits mapped to CWE, OWASP Top 10, and CVSS 3.1 scores. Traces data flow from source to sink. Checks auth, authz, crypto, and dependencies.',
    tools: 11,
    tags: ['CWE', 'OWASP', 'CVSS', 'Data Flow Tracing'],
    output: 'Audit report with vulnerability table, data flow maps, attack paths, remediation',
  },
  {
    id: 'doc-writer',
    name: 'Documentation Writer',
    subtitle: 'Senior Technical Documentation Architect',
    description: 'Reads actual code before writing anything. Produces READMEs, API docs, architecture overviews, and setup guides. Every claim traceable to specific file:line references.',
    tools: 10,
    tags: ['README', 'API Docs', 'Architecture', 'Setup Guides'],
    output: 'Markdown documentation with file:line citations and verification steps',
  },
  {
    id: 'sprint-planner',
    name: 'Sprint Planner',
    subtitle: 'Senior Engineering Manager',
    description: 'Analyzes codebases and git history to create actionable sprint plans. P0/P1/P2 priority. Each task 30-120 minutes with concrete steps and verifiable done-when criteria.',
    tools: 10,
    tags: ['Agile', 'Git Analysis', 'Task Decomposition', 'Delegation'],
    output: 'JSON sprint plan with priority, duration, steps, and completion criteria',
  },
  {
    id: 'sbir-writer',
    name: 'SBIR Proposal Writer',
    subtitle: 'Senior Federal Grant Strategist',
    description: 'Writes SBIR/STTR proposals for DoD, DHS, and NSF. Leads with the agency problem. Quantifies with benchmarks. TAM/SAM/SOM analysis. Work plans with milestones.',
    tools: 7,
    tags: ['DoD', 'DHS', 'NSF', 'TAM/SAM/SOM', 'Compliance'],
    output: 'Complete proposal sections with compliance matrix and evaluation alignment',
  },
  {
    id: 'patent-drafter',
    name: 'Patent Drafter',
    subtitle: 'Software AI/ML Patent Attorney',
    description: 'Drafts provisional patent applications for software and AI/ML inventions. 15-25 claims with proper legal language. Analyzes prior art. Handles Alice Corp. eligibility.',
    tools: 10,
    tags: ['USPTO', 'Claims', 'Alice Corp.', 'Prior Art'],
    output: 'Complete provisional application with claims, specification, and abstract',
  },
];

const hawkDomains = [
  { name: 'ThermalHawk', domain: 'Thermal drone detection', metric: '82.95% mAP', params: '1.77M', color: '#ef4444' },
  { name: 'SentryHawk', domain: 'IRST / missile warning', metric: '86.7% IoU', params: '54K', color: '#f97316' },
  { name: 'DepthHawk', domain: 'Sonar target detection', metric: '88.0% mAP', params: '1.2M', color: '#3b82f6' },
  { name: 'CardioHawk', domain: 'ECG arrhythmia classification', metric: '94.1% F1', params: '8.9K', color: '#10b981' },
  { name: 'ForgeHawk', domain: 'PCB defect inspection', metric: '97.6% mAP', params: '1.5M', color: '#8b5cf6' },
  { name: 'WildHawk', domain: 'Wildlife camera trap ID', metric: 'In progress', params: '< 2M', color: '#C9A84E' },
];
---

<BaseLayout
  title="Products | Thornveil"
  description="Three product lines: RigRun local AI infrastructure, domain expert AI agents, and HawkStack custom ML model training. Built for defense, enterprise, and edge."
>
  <!-- HERO -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-max mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
        Products
      </p>
      <h1 class="text-fluid-3xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
        Three ways to put AI to work
      </h1>
      <p class="text-base mt-4 max-w-2xl leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        Local AI infrastructure, production-ready agents, and custom ML models trained on your data. Everything runs on your hardware. Nothing touches the cloud.
      </p>
    </div>
  </section>

  <!-- TABS -->
  <section class="section-padding pt-8 pb-0">
    <div class="container-max mx-auto">
      <div class="flex gap-1 border-b reveal" style="border-color: var(--color-border-subtle);" id="product-tabs">
        <button class="tab-btn active" data-tab="stack">
          Local AI Stack
        </button>
        <button class="tab-btn" data-tab="agents">
          AI Agents
        </button>
        <button class="tab-btn" data-tab="hawkstack">
          Custom ML Models
        </button>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TAB 1: LOCAL AI STACK -->
  <!-- ============================================================ -->
  <div id="tab-stack" class="tab-content active">

    <!-- RIGRUN FEATURES -->
    <section class="section-padding pt-12">
      <div class="container-max mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-fluid-2xl font-semibold tracking-tight reveal">RigRun</h2>
          <p class="text-sm mt-2 reveal reveal-delay-1" style="color: var(--color-text-secondary);">Complete AI server. One GPU. Zero cloud dependency.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          <div class="reveal reveal-delay-1 card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <h3 class="text-base font-semibold tracking-tight mb-3">122B Model Inference</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                Run a 122-billion parameter model on a single GPU. 105 tokens/second, 65K context window, speculative decoding. Zero per-token costs.
              </p>
            </div>
          </div>
          <div class="reveal reveal-delay-2 card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <h3 class="text-base font-semibold tracking-tight mb-3">5-Layer Safety Stack</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                Prompt injection detection, action gating, trajectory anomaly detection, learned classification, and spillage prevention. 94.86% adversarial block rate.
              </p>
            </div>
          </div>
          <div class="reveal reveal-delay-3 card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <h3 class="text-base font-semibold tracking-tight mb-3">Self-Improving</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                Overnight training pipeline learns from every conversation. DPO preference optimization on your own data. The model gets better at your specific workflows.
              </p>
            </div>
          </div>
        </div>

        <p class="text-center font-mono text-xs tracking-wider mt-8 reveal reveal-delay-4" style="color: var(--color-text-tertiary);">
          RTX PRO 6000 Blackwell &nbsp;///&nbsp; Qwen3.5-122B &nbsp;///&nbsp; 105 tok/s &nbsp;///&nbsp; 65K context &nbsp;///&nbsp; 27 patents filed
        </p>
      </div>
    </section>

    <!-- STACK PRICING -->
    <section class="section-padding" style="background: var(--color-surface-secondary);">
      <div class="container-max mx-auto">
        <div class="text-center mb-14">
          <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Pricing</p>
          <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">Start with the beta. Scale to your own hardware.</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-4xl mx-auto">
          {[
            {
              tier: 'Beta Access',
              price: '$250',
              period: '/month',
              description: '5 seats only. Unlimited inference on a 122B model. No token metering. Direct access to the same stack that powers our products.',
              features: [
                'OpenAI-compatible API endpoint',
                'Unlimited tokens — no metering',
                '122B model (Qwen3.5-122B)',
                'All 6 domain agents included',
                'Native tool calling + reasoning',
                'Priority support (direct line)',
              ],
              cta: 'Apply for Beta',
              featured: true,
              badge: '3 of 5 seats remaining',
            },
            {
              tier: 'RigRun License',
              price: '$2,499',
              period: '/year',
              description: 'Like the beta? Deploy on your own hardware. Your data never leaves your building.',
              features: [
                'Full server binary + desktop app',
                'Unlimited local inference',
                '5-layer safety proxy + routing',
                'Self-training pipeline',
                'Agent Factory (unlimited agents)',
                'Pyros 7-pillar engine',
                '1 year of updates + support',
              ],
              cta: 'Get RigRun',
              featured: false,
            },
            {
              tier: 'Enterprise',
              price: 'Custom',
              period: '',
              description: 'Multi-node, classified environments, mesh networking.',
              features: [
                'Everything in RigRun License',
                'Mycelium mesh networking',
                'Classification routing (CUI–TS)',
                'On-premise installation support',
                'Custom agent development',
                'Dedicated technical support',
              ],
              cta: 'Contact Us',
              featured: false,
            },
          ].map((p, i) => (
            <div
              class={`reveal reveal-delay-${Math.min(i + 1, 4)} rounded-xl p-7 flex flex-col ${p.featured ? 'ring-1' : ''}`}
              style={`background: var(--color-surface-elevated); border: 1px solid ${p.featured ? 'var(--color-accent)' : 'var(--color-border)'}; ${p.featured ? `--tw-ring-color: var(--color-accent); box-shadow: 0 0 30px rgba(201, 168, 78, 0.08);` : ''}`}
            >
              {p.badge && (
                <span class="inline-block self-start font-mono text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full mb-4" style="background: var(--color-accent-muted); color: var(--color-accent);">
                  {p.badge}
                </span>
              )}
              <h3 class="text-lg font-semibold">{p.tier}</h3>
              <div class="mt-2 flex items-baseline gap-1">
                <span class="stat-number text-fluid-xl" style="color: var(--color-accent);">{p.price}</span>
                <span class="text-sm" style="color: var(--color-text-tertiary);">{p.period}</span>
              </div>
              <p class="text-xs mt-2 mb-6" style="color: var(--color-text-tertiary);">{p.description}</p>
              <ul class="space-y-2.5 mb-8 flex-1">
                {p.features.map((f: string) => (
                  <li class="flex items-start gap-2 text-sm" style="color: var(--color-text-secondary);">
                    <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: var(--color-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a
                href={p.tier === 'Enterprise' ? '/contact' : `mailto:jesse@thornveil.ai?subject=${encodeURIComponent(p.tier)}`}
                class={p.featured ? 'btn-primary text-sm text-center justify-center' : 'btn-outline text-sm text-center justify-center'}
              >
                {p.cta}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- ============================================================ -->
  <!-- TAB 2: AI AGENTS -->
  <!-- ============================================================ -->
  <div id="tab-agents" class="tab-content">

    <section class="section-padding pt-12">
      <div class="container-max mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-fluid-2xl font-semibold tracking-tight">Domain Expert Agents</h2>
          <p class="text-sm mt-2" style="color: var(--color-text-secondary);">
            Built by the Agent Factory. 14-step pipeline. Included with every RigRun license and beta seat.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {agents.map((a, i) => (
            <div class={`card-gradient-border p-7 group`} data-tilt>
              <div class="relative z-10">
                <div class="flex items-center justify-between mb-1 flex-wrap gap-2">
                  <h3 class="text-base font-semibold tracking-tight">{a.name}</h3>
                  <span class="font-mono text-[10px] tracking-wider" style="color: var(--color-accent);">{a.tools} tools</span>
                </div>
                <span class="text-[11px]" style="color: var(--color-text-tertiary);">{a.subtitle}</span>
                <p class="text-sm leading-relaxed mt-3 mb-4" style="color: var(--color-text-secondary);">{a.description}</p>
                <div class="rounded-lg p-3 mb-4" style="background: var(--color-surface); border: 1px solid var(--color-border-subtle);">
                  <span class="text-[10px] font-semibold tracking-wider uppercase" style="color: var(--color-text-tertiary);">Output Format</span>
                  <p class="text-xs mt-1 font-mono" style="color: var(--color-text-secondary);">{a.output}</p>
                </div>
                <div class="flex flex-wrap gap-1.5">
                  {a.tags.map((t: string) => (
                    <span class="tag">{t}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- HOW AGENTS ARE MADE -->
    <section class="section-padding" style="background: var(--color-surface-secondary);">
      <div class="container-max mx-auto max-w-3xl text-center">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase" style="color: var(--color-accent);">Powered by Agent Factory</p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 mb-6">How agents are made</h2>
        <p class="text-sm leading-relaxed mb-12" style="color: var(--color-text-secondary);">
          Every agent goes through a 14-step manufacturing pipeline. No manual prompt engineering. No guesswork.
        </p>

        <div class="space-y-10 text-left">
          {[
            {
              phase: 'Design', accent: '#3b82f6',
              steps: [
                { step: '01', label: 'Requirements decomposition', detail: 'Natural language in, structured spec out' },
                { step: '02', label: 'Multi-pass prompt synthesis', detail: 'Draft by 122B, critique by independent model' },
                { step: '03', label: 'Tool selection', detail: 'Auto-selects from 12-tool registry' },
                { step: '04', label: 'Knowledge base assembly', detail: 'ChromaDB with semantic chunking' },
                { step: '05', label: 'Few-shot example generation', detail: '2-3 gold examples per agent' },
                { step: '06', label: 'Tool choreography', detail: 'Frontier model shows how to use tools' },
              ],
            },
            {
              phase: 'Test', accent: '#f97316',
              steps: [
                { step: '07', label: 'Frontier calibration', detail: 'Compare output against Claude Opus' },
                { step: '08', label: 'Gap analysis', detail: 'Identify and fix quality delta' },
                { step: '09', label: 'Adversarial stress test', detail: '5 probes: injection, hallucination, scope' },
                { step: '10', label: 'Prompt hardening', detail: 'Auto-patch for discovered failure modes' },
              ],
            },
            {
              phase: 'Deploy', accent: '#10b981',
              steps: [
                { step: '11', label: 'Functional testing', detail: 'Keyword + structural validation' },
                { step: '12', label: 'Quality gate', detail: '100% happy-path, 50% edge-case pass rate' },
                { step: '13', label: 'Human approval', detail: 'Pending until explicitly activated' },
                { step: '14', label: 'Continuous improvement', detail: 'DPO pairs from production usage' },
              ],
            },
          ].map((group) => (
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="w-2 h-2 rounded-full" style={`background: ${group.accent};`}></span>
                <span class="text-xs font-semibold tracking-[0.2em] uppercase" style={`color: ${group.accent};`}>{group.phase}</span>
                <div class="flex-1 h-px" style="background: var(--color-border-subtle);"></div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {group.steps.map((s) => (
                  <div class="flex gap-4 rounded-lg p-4" style={`border: 1px solid var(--color-border-subtle); border-left: 3px solid ${group.accent};`}>
                    <span class="font-mono text-sm font-bold flex-shrink-0" style={`color: ${group.accent};`}>{s.step}</span>
                    <div>
                      <div class="text-sm font-semibold">{s.label}</div>
                      <div class="text-xs mt-0.5" style="color: var(--color-text-tertiary);">{s.detail}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CUSTOM AGENT CTA -->
    <section class="section-padding relative overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full pointer-events-none" style="opacity: 0.07; background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"></div>
      <div class="relative container-max mx-auto max-w-2xl text-center">
        <h2 class="text-fluid-2xl font-semibold tracking-tight">Need something specific?</h2>
        <p class="mt-4 text-sm max-w-lg mx-auto leading-relaxed" style="color: var(--color-text-secondary);">
          The Agent Factory can build agents for any domain. Legal research, financial analysis, medical literature review, real estate, HR policy, marketing copy. Describe what you need.
        </p>
        <div class="mt-8">
          <a href="mailto:jesse@thornveil.ai?subject=Custom Agent Request" class="btn-primary">
            Request a Custom Agent
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- ============================================================ -->
  <!-- TAB 3: HAWKSTACK CUSTOM ML MODELS -->
  <!-- ============================================================ -->
  <div id="tab-hawkstack" class="tab-content">

    <section class="section-padding pt-12">
      <div class="container-max mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-fluid-2xl font-semibold tracking-tight">HawkStack</h2>
          <p class="text-sm mt-2 max-w-2xl mx-auto" style="color: var(--color-text-secondary);">
            Custom ML models trained on your data. We predict performance before training, build sub-2M parameter models that beat 50M+ competitors, and deploy to edge hardware. Six domains proven. One architecture.
          </p>
        </div>

        <!-- PROVEN DOMAINS TABLE -->
        <div class="card-gradient-border p-7 mb-10">
          <div class="relative z-10">
            <h3 class="text-sm font-semibold tracking-wider uppercase mb-4" style="color: var(--color-text-tertiary);">Proven Domains</h3>
            <div class="space-y-3">
              {hawkDomains.map((d) => (
                <div class="flex items-center gap-4 py-2" style="border-bottom: 1px solid var(--color-border-subtle);">
                  <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background: ${d.color};`}></span>
                  <span class="text-sm font-semibold w-32 flex-shrink-0">{d.name}</span>
                  <span class="text-sm flex-1" style="color: var(--color-text-secondary);">{d.domain}</span>
                  <span class="font-mono text-xs flex-shrink-0" style={`color: ${d.color};`}>{d.metric}</span>
                  <span class="font-mono text-[10px] flex-shrink-0" style="color: var(--color-text-tertiary);">{d.params} params</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- THE MOAT -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
          <div class="card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <h3 class="text-base font-semibold tracking-tight mb-3">Predict Before Training</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                Topology analysis predicts the performance ceiling, optimal architecture, and training recipe before a single model is trained. You know what's achievable before paying for compute.
              </p>
            </div>
          </div>
          <div class="card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <h3 class="text-base font-semibold tracking-tight mb-3">100KB Models Beat 50MB</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                Custom WEM backbone with domain-adaptive receptive field branches. The result: models under 2M parameters that run on $5 microcontrollers while matching models 30x their size.
              </p>
            </div>
          </div>
          <div class="card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <h3 class="text-base font-semibold tracking-tight mb-3">Performance Guarantee</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                If we predict 92% mAP and deliver 85%, money back. The topology theory tells us the physics of your dataset. We only guarantee what the math allows.
              </p>
            </div>
          </div>
        </div>

        <p class="text-center font-mono text-xs tracking-wider mb-8" style="color: var(--color-text-tertiary);">
          6 domains &nbsp;///&nbsp; 4 modalities &nbsp;///&nbsp; 1 architecture &nbsp;///&nbsp; 2 patents filed
        </p>
      </div>
    </section>

    <!-- HAWKSTACK PRICING -->
    <section class="section-padding" style="background: var(--color-surface-secondary);">
      <div class="container-max mx-auto">
        <div class="text-center mb-14">
          <p class="text-[11px] font-semibold tracking-[0.3em] uppercase" style="color: var(--color-accent);">Service Tiers</p>
          <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3">Your data. Your model. Your hardware.</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-4xl mx-auto">
          {[
            {
              tier: 'Topology Audit',
              price: '$2-5K',
              period: '',
              description: 'Know what\'s achievable before you commit. Send us your dataset characteristics — we predict the ceiling.',
              features: [
                '3-parameter topology analysis',
                'Predicted performance ceiling',
                'Recommended architecture',
                'Estimated training time',
                'Dataset sufficiency assessment',
              ],
              cta: 'Request Audit',
            },
            {
              tier: 'Custom Model Build',
              price: '$10-25K',
              period: '',
              description: 'Full model design, training, and validation. Deliverable: trained model (usually <100KB), training code, deployment guide.',
              features: [
                'Everything in Topology Audit',
                'WEM backbone with custom RF branches',
                'SGDR training with basin analysis',
                'Proto heads for imbalanced classes',
                'Trained model + training code',
                'Performance guarantee vs ceiling',
              ],
              cta: 'Start Build',
              featured: true,
              badge: 'Most Popular',
            },
            {
              tier: 'Edge Deployment',
              price: '$25-50K',
              period: '',
              description: 'Full build plus production deployment. ONNX/TensorRT/CoreML export, latency benchmarking, drift detection.',
              features: [
                'Everything in Custom Model Build',
                'ONNX / TensorRT / CoreML export',
                'Target hardware benchmarking',
                'Adaptive inference pipeline',
                'Monitoring + drift detection',
                'Integration support',
              ],
              cta: 'Contact Us',
            },
          ].map((p, i) => (
            <div
              class={`rounded-xl p-7 flex flex-col ${p.featured ? 'ring-1' : ''}`}
              style={`background: var(--color-surface-elevated); border: 1px solid ${p.featured ? 'var(--color-accent)' : 'var(--color-border)'}; ${p.featured ? `--tw-ring-color: var(--color-accent); box-shadow: 0 0 30px rgba(201, 168, 78, 0.08);` : ''}`}
            >
              {p.badge && (
                <span class="inline-block self-start font-mono text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full mb-4" style="background: var(--color-accent-muted); color: var(--color-accent);">
                  {p.badge}
                </span>
              )}
              <h3 class="text-lg font-semibold">{p.tier}</h3>
              <div class="mt-2 flex items-baseline gap-1">
                <span class="stat-number text-fluid-xl" style="color: var(--color-accent);">{p.price}</span>
                <span class="text-sm" style="color: var(--color-text-tertiary);">{p.period}</span>
              </div>
              <p class="text-xs mt-2 mb-6" style="color: var(--color-text-tertiary);">{p.description}</p>
              <ul class="space-y-2.5 mb-8 flex-1">
                {p.features.map((f: string) => (
                  <li class="flex items-start gap-2 text-sm" style="color: var(--color-text-secondary);">
                    <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: var(--color-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a
                href={`mailto:jesse@thornveil.ai?subject=${encodeURIComponent('HawkStack ' + p.tier)}`}
                class={p.featured ? 'btn-primary text-sm text-center justify-center' : 'btn-outline text-sm text-center justify-center'}
              >
                {p.cta}
              </a>
            </div>
          ))}
        </div>

        <p class="text-center text-xs mt-8" style="color: var(--color-text-tertiary);">
          Target markets: defense/intelligence, medical devices, industrial inspection, wildlife conservation.
          <br />ROI story: a $15K model that runs on a $5 MCU saves $500K/year in GPU deployment costs across your fleet.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .tab-btn {
    padding: 0.75rem 1.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-text-tertiary);
    border-bottom: 2px solid transparent;
    background: none;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .tab-btn:hover {
    color: var(--color-text-primary);
  }
  .tab-btn.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .tab-content {
    display: none;
  }
  .tab-content.active {
    display: block;
  }
</style>

<script>
  import Lenis from 'lenis';
  const lenis = new Lenis({ duration: 1.2, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
  function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);

  // Tab switching
  document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach((c) => c.classList.remove('active'));
      btn.classList.add('active');
      const target = document.getElementById('tab-' + btn.dataset.tab);
      if (target) target.classList.add('active');
    });
  });

  // Card tilt
  document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
    const MAX_DEG = 3;
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;
      card.style.transform = `perspective(800px) rotateX(${(0.5 - y) * MAX_DEG}deg) rotateY(${(x - 0.5) * MAX_DEG}deg)`;
      card.style.transition = 'transform 0.1s ease-out';
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg)';
      card.style.transition = 'transform 0.4s ease-out';
    });
  });
</script>
