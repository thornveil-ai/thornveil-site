---
import BaseLayout from '../layouts/BaseLayout.astro';

const agents = [
  {
    id: 'code-reviewer',
    name: 'Code Reviewer',
    subtitle: 'Senior Principal Security Engineer',
    description: 'Finds real bugs, security vulnerabilities, and performance bottlenecks. Produces structured JSON reviews with severity ratings, file:line locations, impact analysis, and concrete fix suggestions. Strictly avoids style nitpicks.',
    tools: 9,
    tags: ['Security', 'Bug Detection', 'Performance', 'Static Analysis'],
    output: 'Structured JSON with verdict, severity, file:line, impact, fix suggestion',
    featured: true,
  },
  {
    id: 'security-auditor',
    name: 'Security Auditor',
    subtitle: 'Principal Application Security Engineer',
    description: 'Comprehensive code audits mapped to CWE, OWASP Top 10, and CVSS 3.1 scores. Traces data flow from source to sink. Checks auth, authz, crypto, and dependencies. Produces attack path documentation with Mermaid diagrams.',
    tools: 11,
    tags: ['CWE', 'OWASP', 'CVSS', 'Data Flow Tracing'],
    output: 'Audit report with vulnerability table, data flow maps, attack paths, remediation',
    featured: true,
  },
  {
    id: 'doc-writer',
    name: 'Documentation Writer',
    subtitle: 'Senior Technical Documentation Architect',
    description: 'Reads actual code before writing anything. Produces READMEs, API docs, architecture overviews, and setup guides. Every claim traceable to specific file:line references. Will not hallucinate functionality.',
    tools: 10,
    tags: ['README', 'API Docs', 'Architecture', 'Setup Guides'],
    output: 'Markdown documentation with file:line citations and verification steps',
  },
  {
    id: 'sprint-planner',
    name: 'Sprint Planner',
    subtitle: 'Senior Engineering Manager',
    description: 'Analyzes codebases and git history to create actionable sprint plans. P0/P1/P2 priority. Each task 30-120 minutes with concrete steps and verifiable done-when criteria. Max 8 tasks. Can delegate to other agents.',
    tools: 10,
    tags: ['Agile', 'Git Analysis', 'Task Decomposition', 'Delegation'],
    output: 'JSON sprint plan with priority, duration, steps, and completion criteria',
  },
  {
    id: 'sbir-writer',
    name: 'SBIR Proposal Writer',
    subtitle: 'Senior Federal Grant Strategist',
    description: 'Writes SBIR/STTR proposals for DoD, DHS, and NSF. Leads with the agency problem. Quantifies with benchmarks. Structures every section to match evaluation criteria. TAM/SAM/SOM analysis. Work plans with milestones.',
    tools: 7,
    tags: ['DoD', 'DHS', 'NSF', 'TAM/SAM/SOM', 'Compliance'],
    output: 'Complete proposal sections with compliance matrix and evaluation alignment',
  },
  {
    id: 'patent-drafter',
    name: 'Patent Drafter',
    subtitle: 'Software AI/ML Patent Attorney',
    description: 'Drafts provisional patent applications for software and AI/ML inventions. 15-25 claims with proper legal language. Analyzes prior art. Handles Alice Corp. eligibility. Reads existing code to ensure enablement.',
    tools: 10,
    tags: ['USPTO', 'Claims', 'Alice Corp.', 'Prior Art'],
    output: 'Complete provisional application with claims, specification, and abstract',
  },
];

const pricing = [
  {
    tier: 'Beta Access',
    price: '$250',
    period: '/month',
    description: '5 seats only. Unlimited inference on a 122B model. No token metering, no throttling. Direct access to the same stack that powers our products.',
    features: [
      'OpenAI-compatible API endpoint',
      'Unlimited tokens — no metering',
      '122B model (Qwen3.5-122B-A10B)',
      'All 6 domain agents included',
      'Native tool calling + reasoning',
      'Priority support (direct line)',
    ],
    cta: 'Apply for Beta',
    featured: true,
    badge: '3 of 5 seats remaining',
  },
  {
    tier: 'RigRun License',
    price: '$2,499',
    period: '/year',
    description: 'Like what you see in the beta? Deploy the full stack on your own hardware. Your data never leaves your building.',
    features: [
      'Full server binary + desktop app',
      'Unlimited local inference',
      '5-layer safety proxy + cascade routing',
      'Self-training pipeline',
      'Agent Factory (create unlimited agents)',
      'Pyros 7-pillar inference engine',
      '1 year of updates + support',
    ],
    cta: 'Get RigRun',
    featured: false,
  },
  {
    tier: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'Multi-node, classified environments, mesh networking.',
    features: [
      'Everything in RigRun License',
      'Mycelium mesh networking',
      'Classification-aware routing (CUI through TS)',
      'On-premise installation support',
      'Custom agent development',
      'Dedicated technical support',
    ],
    cta: 'Contact Us',
    featured: false,
  },
];
---

<BaseLayout
  title="Products | Thornveil"
  description="RigRun: local AI infrastructure on your hardware. 122B model inference, 5-layer safety stack, self-improving training pipeline, and domain expert agents."
>
  <!-- HERO -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-max mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
        Products
      </p>
      <h1 class="text-fluid-3xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
        Local AI infrastructure. Your hardware, your data.
      </h1>
      <p class="text-base mt-4 max-w-2xl leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        RigRun is a complete AI server that runs on your hardware with zero cloud dependency. One binary, one GPU, everything included — inference, safety, routing, training, and a full agent factory.
      </p>
    </div>
  </section>

  <!-- RIGRUN -->
  <section class="section-padding pt-12">
    <div class="container-max mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-fluid-2xl font-semibold tracking-tight reveal">
          RigRun
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="reveal reveal-delay-1 card-gradient-border p-7" data-tilt>
          <div class="relative z-10">
            <h3 class="text-base font-semibold tracking-tight mb-3">122B Model Inference</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              Run a 122-billion parameter model on a single GPU. 105 tokens/second, 65K context window, speculative decoding. Zero API costs.
            </p>
          </div>
        </div>
        <div class="reveal reveal-delay-2 card-gradient-border p-7" data-tilt>
          <div class="relative z-10">
            <h3 class="text-base font-semibold tracking-tight mb-3">5-Layer Safety Stack</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              Prompt injection detection, action gating, trajectory anomaly detection, learned classification, and spillage prevention. 94.86% adversarial block rate.
            </p>
          </div>
        </div>
        <div class="reveal reveal-delay-3 card-gradient-border p-7" data-tilt>
          <div class="relative z-10">
            <h3 class="text-base font-semibold tracking-tight mb-3">Self-Improving</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              Overnight training pipeline learns from every conversation. DPO preference optimization on your own data. The model gets better at your specific workflows.
            </p>
          </div>
        </div>
      </div>

      <p class="text-center font-mono text-xs tracking-wider mt-8 reveal reveal-delay-4" style="color: var(--color-text-tertiary);">
        RTX PRO 6000 Blackwell &nbsp;///&nbsp; Qwen3.5-122B &nbsp;///&nbsp; 105 tok/s &nbsp;///&nbsp; 65K context &nbsp;///&nbsp; 27 patents filed
      </p>
    </div>
  </section>

  <!-- AGENT CATALOG -->
  <section class="section-padding pt-12" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-fluid-2xl font-semibold tracking-tight reveal">
          Domain Expert Agents
        </h2>
        <p class="text-sm mt-3 reveal reveal-delay-1" style="color: var(--color-text-secondary);">
          Included with every RigRun license.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {agents.map((a, i) => (
          <div
            class={`reveal reveal-delay-${Math.min(i + 1, 4)} card-gradient-border p-7 group ${a.featured ? 'md:col-span-1' : ''}`}
            data-tilt
          >
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-1 flex-wrap gap-2">
                <h3 class="text-base font-semibold tracking-tight">{a.name}</h3>
                <span class="font-mono text-[10px] tracking-wider" style="color: var(--color-accent);">{a.tools} tools</span>
              </div>
              <span class="text-[11px]" style="color: var(--color-text-tertiary);">{a.subtitle}</span>

              <p class="text-sm leading-relaxed mt-3 mb-4" style="color: var(--color-text-secondary);">
                {a.description}
              </p>

              <div class="rounded-lg p-3 mb-4" style="background: var(--color-surface); border: 1px solid var(--color-border-subtle);">
                <span class="text-[10px] font-semibold tracking-wider uppercase" style="color: var(--color-text-tertiary);">Output Format</span>
                <p class="text-xs mt-1 font-mono" style="color: var(--color-text-secondary);">{a.output}</p>
              </div>

              <div class="flex flex-wrap gap-1.5">
                {a.tags.map((t: string) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section-padding">
    <div class="container-max mx-auto max-w-3xl text-center">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
        Powered by Agent Factory
      </p>
      <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 mb-6 reveal reveal-delay-1">
        How agents are made
      </h2>
      <p class="text-sm leading-relaxed mb-12 reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        Every agent goes through a 14-step manufacturing pipeline. No manual prompt engineering. No guesswork.
      </p>

      <div class="space-y-10 text-left">
        {[
          {
            phase: 'Design',
            accent: '#3b82f6',
            steps: [
              { step: '01', label: 'Requirements decomposition', detail: 'Natural language in, structured spec out' },
              { step: '02', label: 'Multi-pass prompt synthesis', detail: 'Draft by 122B, critique by independent model' },
              { step: '03', label: 'Tool selection', detail: 'Auto-selects from 12-tool registry' },
              { step: '04', label: 'Knowledge base assembly', detail: 'ChromaDB with semantic chunking' },
              { step: '05', label: 'Few-shot example generation', detail: '2-3 gold examples per agent' },
              { step: '06', label: 'Tool choreography', detail: 'Frontier model shows how to use tools' },
            ],
          },
          {
            phase: 'Test',
            accent: '#f97316',
            steps: [
              { step: '07', label: 'Frontier calibration', detail: 'Compare output against Claude Opus' },
              { step: '08', label: 'Gap analysis', detail: 'Identify and fix quality delta' },
              { step: '09', label: 'Adversarial stress test', detail: '5 probes: injection, hallucination, scope' },
              { step: '10', label: 'Prompt hardening', detail: 'Auto-patch for discovered failure modes' },
            ],
          },
          {
            phase: 'Deploy',
            accent: '#10b981',
            steps: [
              { step: '11', label: 'Functional testing', detail: 'Keyword + structural validation' },
              { step: '12', label: 'Quality gate', detail: '100% happy-path, 50% edge-case pass rate' },
              { step: '13', label: 'Human approval', detail: 'Pending until explicitly activated' },
              { step: '14', label: 'Continuous improvement', detail: 'DPO pairs from production usage' },
            ],
          },
        ].map((group) => (
          <div class="reveal">
            <div class="flex items-center gap-3 mb-4">
              <span class="w-2 h-2 rounded-full" style={`background: ${group.accent};`}></span>
              <span class="text-xs font-semibold tracking-[0.2em] uppercase" style={`color: ${group.accent};`}>{group.phase}</span>
              <div class="flex-1 h-px" style="background: var(--color-border-subtle);"></div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {group.steps.map((s) => (
                <div
                  class="flex gap-4 rounded-lg p-4"
                  style={`border: 1px solid var(--color-border-subtle); border-left: 3px solid ${group.accent};`}
                >
                  <span class="font-mono text-sm font-bold flex-shrink-0" style={`color: ${group.accent};`}>{s.step}</span>
                  <div>
                    <div class="text-sm font-semibold">{s.label}</div>
                    <div class="text-xs mt-0.5" style="color: var(--color-text-tertiary);">{s.detail}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="section-padding" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <div class="text-center mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Pricing
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          Simple, transparent pricing
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-4xl mx-auto">
        {pricing.map((p, i) => (
          <div
            class={`reveal reveal-delay-${Math.min(i + 1, 4)} rounded-xl p-7 flex flex-col ${p.featured ? 'ring-1' : ''}`}
            style={`background: var(--color-surface-elevated); border: 1px solid ${p.featured ? 'var(--color-accent)' : 'var(--color-border)'}; ${p.featured ? `--tw-ring-color: var(--color-accent); box-shadow: 0 0 30px rgba(201, 168, 78, 0.08);` : ''}`}
          >
            {p.badge && (
              <span class="inline-block self-start font-mono text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full mb-4" style="background: var(--color-accent-muted); color: var(--color-accent);">
                {p.badge}
              </span>
            )}
            <h3 class="text-lg font-semibold">{p.tier}</h3>
            <div class="mt-2 flex items-baseline gap-1">
              <span class="stat-number text-fluid-xl" style="color: var(--color-accent);">{p.price}</span>
              <span class="text-sm" style="color: var(--color-text-tertiary);">{p.period}</span>
            </div>
            <p class="text-xs mt-2 mb-6" style="color: var(--color-text-tertiary);">{p.description}</p>

            <ul class="space-y-2.5 mb-8 flex-1">
              {p.features.map((f: string) => (
                <li class="flex items-start gap-2 text-sm" style="color: var(--color-text-secondary);">
                  <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: var(--color-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a
              href={p.tier === 'Enterprise' ? '/contact' : 'mailto:jesse@thornveil.ai?subject=' + encodeURIComponent(p.tier)}
              class={p.featured ? 'btn-primary text-sm text-center justify-center' : 'btn-outline text-sm text-center justify-center'}
            >
              {p.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CUSTOM AGENT CTA -->
  <section class="section-padding relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full pointer-events-none" style="opacity: 0.07; background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"></div>

    <div class="relative container-max mx-auto max-w-2xl text-center">
      <h2 class="text-fluid-2xl font-semibold tracking-tight reveal">
        Need something specific?
      </h2>
      <p class="mt-4 text-sm max-w-lg mx-auto leading-relaxed reveal reveal-delay-1" style="color: var(--color-text-secondary);">
        The Agent Factory can build agents for any domain. Legal research, financial analysis, medical literature review, real estate, HR policy, marketing copy. Describe what you need. The factory handles the rest.
      </p>
      <div class="mt-8 reveal reveal-delay-2">
        <a href="mailto:jesse@thornveil.ai?subject=Custom Agent Request" class="btn-primary">
          Request a Custom Agent
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  const lenis = new Lenis({ duration: 1.2, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
  function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);

  document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
    const MAX_DEG = 3;
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;
      card.style.transform = `perspective(800px) rotateX(${(0.5 - y) * MAX_DEG}deg) rotateY(${(x - 0.5) * MAX_DEG}deg)`;
      card.style.transition = 'transform 0.1s ease-out';
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg)';
      card.style.transition = 'transform 0.4s ease-out';
    });
  });
</script>
