---
import BaseLayout from '../layouts/BaseLayout.astro';

const agents = [
  {
    id: 'code-reviewer',
    name: 'Code Reviewer',
    subtitle: 'Senior Principal Security Engineer',
    description: 'Finds real bugs, security vulnerabilities, and performance bottlenecks. Produces structured JSON reviews with severity ratings, file:line locations, impact analysis, and concrete fix suggestions.',
    tools: 9,
    tags: ['Security', 'Bug Detection', 'Performance', 'Static Analysis'],
    output: 'Structured JSON with verdict, severity, file:line, impact, fix suggestion',
  },
  {
    id: 'security-auditor',
    name: 'Security Auditor',
    subtitle: 'Principal Application Security Engineer',
    description: 'Comprehensive code audits mapped to CWE, OWASP Top 10, and CVSS 3.1 scores. Traces data flow from source to sink. Checks auth, authz, crypto, and dependencies.',
    tools: 11,
    tags: ['CWE', 'OWASP', 'CVSS', 'Data Flow Tracing'],
    output: 'Audit report with vulnerability table, data flow maps, attack paths, remediation',
  },
  {
    id: 'doc-writer',
    name: 'Documentation Writer',
    subtitle: 'Senior Technical Documentation Architect',
    description: 'Reads actual code before writing anything. Produces READMEs, API docs, architecture overviews, and setup guides. Every claim traceable to specific file:line references.',
    tools: 10,
    tags: ['README', 'API Docs', 'Architecture', 'Setup Guides'],
    output: 'Markdown documentation with file:line citations and verification steps',
  },
  {
    id: 'sprint-planner',
    name: 'Sprint Planner',
    subtitle: 'Senior Engineering Manager',
    description: 'Analyzes codebases and git history to create actionable sprint plans. P0/P1/P2 priority. Each task 30-120 minutes with concrete steps and verifiable done-when criteria.',
    tools: 10,
    tags: ['Agile', 'Git Analysis', 'Task Decomposition', 'Delegation'],
    output: 'JSON sprint plan with priority, duration, steps, and completion criteria',
  },
  {
    id: 'sbir-writer',
    name: 'SBIR Proposal Writer',
    subtitle: 'Senior Federal Grant Strategist',
    description: 'Writes SBIR/STTR proposals for DoD, DHS, and NSF. Leads with the agency problem. Quantifies with benchmarks. TAM/SAM/SOM analysis. Work plans with milestones.',
    tools: 7,
    tags: ['DoD', 'DHS', 'NSF', 'TAM/SAM/SOM', 'Compliance'],
    output: 'Complete proposal sections with compliance matrix and evaluation alignment',
  },
  {
    id: 'patent-drafter',
    name: 'Patent Drafter',
    subtitle: 'Software AI/ML Patent Attorney',
    description: 'Drafts provisional patent applications for software and AI/ML inventions. 15-25 claims with proper legal language. Analyzes prior art. Handles Alice Corp. eligibility.',
    tools: 10,
    tags: ['USPTO', 'Claims', 'Alice Corp.', 'Prior Art'],
    output: 'Complete provisional application with claims, specification, and abstract',
  },
];

const hawkDomains = [
  { name: 'ThermalHawk', domain: 'Thermal drone detection', metric: '82.95% mAP', params: '1.77M', color: '#ef4444' },
  { name: 'SentryHawk', domain: 'IRST / missile warning', metric: '86.7% IoU', params: '54K', color: '#f97316' },
  { name: 'DepthHawk', domain: 'Sonar target detection', metric: '88.0% mAP', params: '1.2M', color: '#3b82f6' },
  { name: 'CardioHawk', domain: 'ECG arrhythmia classification', metric: '94.1% F1', params: '8.9K', color: '#10b981' },
  { name: 'ForgeHawk', domain: 'PCB defect inspection', metric: '97.6% mAP', params: '1.5M', color: '#8b5cf6' },
  { name: 'WildHawk', domain: 'Wildlife camera trap ID', metric: 'Active R&D', params: '< 2M', color: '#C9A84E' },
];

const pyrosPillars = [
  { num: 'I', name: 'Oracle', role: 'Predictive intel', description: 'Forecasts request load via time-series, UCB1-routes by difficulty, emits skip signals so downstream pillars can short-circuit easy queries.' },
  { num: 'II', name: 'Tribunal', role: 'Adversarial verification', description: '6-feature hallucination probe with weighted scoring. Optional reward-model integration. Courtroom-style structured verification workflow.' },
  { num: 'III', name: 'Fortress', role: 'Pre-inference defense', description: 'Prompt injection BLOCKS at confidence ≥ 0.7. SmoothLLM stability check (Robey 2023). Negative-selection AIS detectors learn your traffic\'s baseline.' },
  { num: 'IV', name: 'MindEye', role: 'Metacognition', description: 'Knowledge-graph context injection. Epigenetic temperature/token suggestions. Pure-Go isotonic calibration writing a QualityScore on every response.' },
  { num: 'V', name: 'Forge', role: 'Self-improvement', description: 'EvoPrompt crossover for prompt evolution. MDL prompt compression. DICE training-exemplar capture. The pipeline gets sharper on your workload over time.' },
  { num: 'VI', name: 'Crucible', role: 'Operational safety', description: 'Circuit breakers, OpenTelemetry trace spans, Shannon-entropy criticality scoring, pheromone-style stigmergic blackboard for inter-agent signaling.' },
  { num: 'VII', name: 'Singularity', role: 'Homeostatic regulation', description: 'PID controller over runtime vitals with anti-windup. Superposition activation for parallel candidates. Discrete-event digital-twin simulator.' },
];

const pyrosFeatures = [
  { title: 'Prompt injection blocking', detail: 'Blocks at confidence ≥ 0.7 before the request reaches the model. SmoothLLM perturbation + supermajority vote layered on top.', citation: 'pillar/fortress.go:47' },
  { title: 'Hallucination probe', detail: '6 weighted features: 4-gram repetition, entity consistency, numeric density, hedge density, entropy variance, confidence gap.', citation: 'hallucination/probe.go:70' },
  { title: 'Isotonic calibration', detail: 'Pure-Go PAVA implementation, validated against sklearn 1.4. Honestly labeled "QualityScore" — not a calibrated probability.', citation: 'calibration/calibration.go:226' },
  { title: 'Constant-time auth', detail: 'Mandatory bearer token for non-localhost binds. Compared via subtle.ConstantTimeCompare. Timing-attack hardened by default.', citation: 'server_auth.go:53' },
  { title: 'Admission + graceful shutdown', detail: 'Sized inbound semaphore, in-flight WaitGroup, async PostWorker drained before persistence so bookkeeping writes never get lost.', citation: 'pyros.go:138' },
  { title: 'Audit chain', detail: 'JSON-Lines audit sink with mutex serialization. Pluggable backend interface — file sink ships, syslog/network sinks slot in.', citation: 'audit/file_sink.go' },
];

const pyrosResearch = [
  { paper: 'SmoothLLM', authors: 'Robey, Wong, Hassani, Kolter (2023)', use: 'Fortress stability check' },
  { paper: 'EvoPrompt', authors: 'Guo et al. (2023)', use: 'Forge prompt evolution' },
  { paper: 'PAVA / isotonic regression', authors: 'Zadrozny & Elkan (2002)', use: 'MindEye calibration' },
  { paper: 'UCB1 contextual bandit', authors: 'Auer, Cesa-Bianchi, Fischer (2002)', use: 'Oracle cascade routing' },
  { paper: 'Negative Selection (AIS)', authors: 'Forrest, Perelson, Allen (1994)', use: 'Fortress immune detectors' },
  { paper: 'PID with anti-windup', authors: 'Aström & Hägglund (2006)', use: 'Singularity homeostasis' },
  { paper: 'Minimum Description Length', authors: 'Rissanen (1978)', use: 'Forge prompt compression' },
];

const myceliumInnovations = [
  {
    name: 'Distributed MoE Expert Routing',
    file: 'mesh/expert_proxy.go',
    description: 'The mesh expert system tracks which peers host which model experts via the gossip protocol. When a query arrives, the expert registry locates the best peer for each required expert computation by load and latency. An expert proxy dispatches computation requests with predictive prefetching — firing async requests during the attention computation window to hide network latency.',
  },
  {
    name: 'Cross-Model Style Consistency',
    file: 'mesh/style.go',
    description: 'Different nodes may run different model sizes (0.6B to 122B parameters). The style normalizer applies post-generation processing to ensure consistent tone, formatting, and verbosity regardless of which node generated the response. Hedging removal, preamble stripping, code-block normalization, verbosity control. Seamless escalation uses entropy monitoring to detect when a small model is uncertain and transparently hand off mid-generation to a larger peer.',
  },
  {
    name: 'Proof-of-Inference (PoI)',
    file: 'mesh/poi.go',
    description: 'Three-layer cryptographic verification ensuring mesh nodes perform honest computation. Behavioral fingerprinting catches model substitution. Merkle execution traces catch computation shortcuts. Economic reputation with 1% spot-check rate makes persistent dishonesty unprofitable. Combined verdict: 0.3·fingerprint + 0.3·trace + 0.4·reputation.',
  },
];

const myceliumStack = [
  { layer: '8', name: 'Application', detail: 'OpenAI-compatible API, chat, files' },
  { layer: '7', name: 'Routing & Verification', detail: 'Cascade router, PoI, reputation' },
  { layer: '6', name: 'Style Consistency', detail: 'Post-generation normalization' },
  { layer: '5', name: 'Expert Orchestrator', detail: 'Registry, proxy, prefetching' },
  { layer: '4', name: 'Transport', detail: 'HTTP/SSE forwarding, NAT traversal' },
  { layer: '3', name: 'Network Topology', detail: 'Kademlia DHT, gossip, mDNS' },
  { layer: '2', name: 'Backend Abstraction', detail: 'Ollama, llama.cpp, SGLang' },
  { layer: '1', name: 'Hardware Detection', detail: 'GPU/CPU/NPU discovery & tiering' },
];

const myceliumTiers = [
  { tier: 'Micro', hardware: 'Raspberry Pi, Mobile', capacity: '0.6B – 3B', role: 'Edge routing, simple queries', color: '#3b82f6' },
  { tier: 'Edge', hardware: 'Laptop (8GB), Jetson', capacity: '3B – 8B', role: 'Token gen, classification', color: '#10b981' },
  { tier: 'Standard', hardware: 'Desktop GPU (RTX 3060+)', capacity: '8B – 14B', role: 'General inference', color: '#f59e0b' },
  { tier: 'Power', hardware: 'Workstation (24GB+ VRAM)', capacity: '14B – 70B', role: 'Complex reasoning, expert hosting', color: '#f97316' },
  { tier: 'Fortress', hardware: 'Multi-GPU server', capacity: '70B+', role: 'Heavy inference, training, aggregation', color: '#ef4444' },
];

const myceliumProtocols = [
  {
    name: 'Discovery (mDNS + DHT + STUN)',
    detail: 'LAN: mDNS advertisement under _mycelium._tcp.local. with capability metadata. DHT: Kademlia 160-bit node IDs, k=20 buckets. WAN: UPnP port mapping + STUN (RFC 5389) for NAT traversal. Manual peer registration available for cross-subnet connectivity.',
  },
  {
    name: 'Adapter Gossip Protocol (AGP)',
    detail: 'Nodes share locally-trained LoRA/QLoRA adapters via epidemic gossip. Announcements propagate with fanout=3 every 2 minutes. Adapters carry loss metrics, dataset size, and weight hashes. Receiving nodes evaluate against local test sets. BitTorrent-style chunked transfer (64MB chunks, SHA-256 verified).',
  },
  {
    name: 'Model Distribution Protocol (MDP)',
    detail: 'Full model files distributed across the mesh. Chunked transfer with parallel downloads (4 concurrent, 64MB per chunk), SHA-256 per-chunk and full-file verification, resume support for interrupted transfers.',
  },
];

const myceliumPhases = [
  { phase: '1', name: 'Core Protocol', status: 'Complete', detail: 'mDNS discovery, DHT, peer registry, health checking' },
  { phase: '2', name: 'Query Routing', status: 'Complete', detail: '7-stage cascade, SSE forwarding, load balancing, gossip' },
  { phase: '3', name: 'Distributed Inference', status: 'Complete', detail: 'Expert registry, computation proxy, prefetching, PoI' },
  { phase: '4', name: 'Consistency', status: 'Complete', detail: 'Style normalization, seamless escalation, adapter sharing' },
  { phase: '5', name: 'WAN Scaling', status: 'Complete', detail: 'NAT traversal (UPnP + STUN), DHT-based WAN discovery' },
  { phase: '6', name: 'Production Hardening', status: 'In Progress', detail: 'End-to-end integration tests, multi-node stress testing' },
];
---

<BaseLayout
  title="Products | Thornveil"
  description="Five product lines: RigRun local AI infrastructure, Pyros LLM safety engine, Mycelium distributed AI mesh, HawkStack custom ML model training, and domain expert AI agents. Built for defense, enterprise, and edge."
>
  <!-- HERO -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-max mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
        Products
      </p>
      <h1 class="text-fluid-3xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
        Five ways to put AI to work
      </h1>
      <p class="text-base mt-4 max-w-2xl leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        Local AI infrastructure, production-ready agents, custom ML models trained on your data, a standalone safety engine for any LLM, and a P2P mesh that scales across whatever devices you already have. Everything runs on your hardware. Nothing touches the cloud.
      </p>
    </div>
  </section>

  <!-- TABS -->
  <section class="section-padding pt-8 pb-0">
    <div class="container-max mx-auto">
      <div class="flex gap-1 border-b reveal" style="border-color: var(--color-border-subtle);" id="product-tabs">
        <button class="tab-btn active" data-tab="stack">
          Local AI Stack
        </button>
        <button class="tab-btn" data-tab="agents">
          AI Agents
        </button>
        <button class="tab-btn" data-tab="hawkstack">
          Custom ML Models
        </button>
        <button class="tab-btn" data-tab="pyros">
          Pyros Safety Engine
        </button>
        <button class="tab-btn" data-tab="mycelium">
          Mycelium Mesh
        </button>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TAB 1: LOCAL AI STACK -->
  <!-- ============================================================ -->
  <div id="tab-stack" class="tab-content active">

    <!-- RIGRUN FEATURES -->
    <section class="section-padding pt-12">
      <div class="container-max mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-fluid-2xl font-semibold tracking-tight reveal">RigRun</h2>
          <p class="text-sm mt-2 reveal reveal-delay-1" style="color: var(--color-text-secondary);">Complete AI server. One GPU. Zero cloud dependency.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          <div class="reveal reveal-delay-1 card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <h3 class="text-base font-semibold tracking-tight mb-3">122B Model Inference</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                Run a 122-billion parameter model on a single GPU. 105 tokens/second, 1M-token context window (YaRN-scaled). Zero per-token costs.
              </p>
            </div>
          </div>
          <div class="reveal reveal-delay-2 card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <h3 class="text-base font-semibold tracking-tight mb-3">5-Layer Safety Stack</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                Prompt injection detection, action gating, trajectory anomaly detection, learned classification, and spillage prevention. 100% adversarial block rate at confidence threshold.
              </p>
            </div>
          </div>
          <div class="reveal reveal-delay-3 card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <h3 class="text-base font-semibold tracking-tight mb-3">Self-Improving</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                Overnight training pipeline learns from every conversation. DPO preference optimization on your own data. The model gets better at your specific workflows.
              </p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-1 gap-5 mt-5">
          <div class="reveal reveal-delay-4 card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                <h3 class="text-base font-semibold tracking-tight">Rolling Memory — Effectively Infinite Context</h3>
                <span class="inline-flex items-center gap-1 font-mono text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full" style="background: var(--color-accent-muted); color: var(--color-accent);">
                  Verified 2026-04-11
                </span>
              </div>
              <p class="text-sm leading-relaxed mb-5" style="color: var(--color-text-secondary);">
                Beyond the 1M-token native window, Rolling Memory v4 extends effective context indefinitely through per-session disk-backed verbatim, summary, and embedding tiers. Latency stays flat with depth because retrieval keeps each forward pass roughly the same size regardless of total context length.
              </p>
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                {[
                  { value: '10M', label: 'Characters tested' },
                  { value: '2.5M', label: 'Tokens tested' },
                  { value: '100%', label: 'Needle recall' },
                  { value: '~10s', label: 'Latency at any depth' },
                ].map((m) => (
                  <div class="rounded-lg p-3 text-center" style="background: var(--color-surface); border: 1px solid var(--color-border-subtle);">
                    <div class="font-mono text-base font-bold" style="color: var(--color-accent);">{m.value}</div>
                    <div class="font-mono text-[9px] tracking-wider uppercase mt-1" style="color: var(--color-text-tertiary);">{m.label}</div>
                  </div>
                ))}
              </div>
              <p class="text-[11px] mt-4 leading-relaxed" style="color: var(--color-text-tertiary);">
                Test rig: needle-in-haystack 100% pass through 10M chars (8.9–9.1s), 5/5 fact consistency, 10/10 multi-turn retrieval, 17/17 smoke tests passed. Drop-in OpenAI/Anthropic-compatible reverse proxy on port 8096 with per-session isolation, dashboard, and Prometheus metrics.
              </p>
            </div>
          </div>
        </div>

        <p class="text-center font-mono text-xs tracking-wider mt-8 reveal reveal-delay-4" style="color: var(--color-text-tertiary);">
          RTX PRO 6000 Blackwell &nbsp;///&nbsp; Qwen3.5-122B &nbsp;///&nbsp; 105 tok/s &nbsp;///&nbsp; 1M token context &nbsp;///&nbsp; Runs on your hardware
        </p>
      </div>
    </section>

    <!-- COMPANION APPS -->
    <section class="section-padding pt-0">
      <div class="container-max mx-auto">
        <div class="text-center mb-10">
          <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Companion Apps</p>
          <h3 class="text-fluid-xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">Talk to your stack from any surface</h3>
          <p class="text-sm mt-3 max-w-2xl mx-auto reveal reveal-delay-2" style="color: var(--color-text-secondary);">
            Native desktop and mobile clients that speak directly to your RigRun server. Both ship with the same OpenAI-compatible API contract auto-generated from the Go server's OpenAPI spec.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="reveal reveal-delay-1 card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                <h4 class="text-base font-semibold tracking-tight">RigRun Desktop</h4>
                <span class="inline-flex items-center gap-1 font-mono text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full" style="background: var(--color-accent-muted); color: var(--color-accent);">
                  Pre-release
                </span>
              </div>
              <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-secondary);">
                Electron + Next.js 14 + React. Bundles its own RigRun Go backend so a single installer ships the server and the UI together. WebAssembly LLM in the renderer (via @mlc-ai/web-llm) provides a second inference path independent of the Go backend.
              </p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {['Electron', 'Next.js 14', 'React', 'Tiptap', 'Radix UI', 'Vitest + Playwright'].map((t) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
              <div class="font-mono text-[10px] tracking-wider uppercase" style="color: var(--color-text-tertiary);">
                <span style="color: var(--color-accent);">~24,000 lines</span> &nbsp;TypeScript / TSX &nbsp;&middot;&nbsp; Windows / macOS / Linux
              </div>
            </div>
          </div>

          <div class="reveal reveal-delay-2 card-gradient-border p-7" data-tilt>
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                <h4 class="text-base font-semibold tracking-tight">RigRun Mobile</h4>
                <span class="inline-flex items-center gap-1 font-mono text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full" style="background: var(--color-surface); color: var(--color-text-tertiary); border: 1px solid var(--color-border);">
                  Not yet released
                </span>
              </div>
              <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-secondary);">
                Flutter native app for iOS and Android. Riverpod state, Hive storage, Dio HTTP, freezed models, flutter_secure_storage for credentials. Connects to your RigRun server over Tailscale or any private mesh — your data never touches a third-party cloud.
              </p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {['Flutter', 'Riverpod', 'Hive', 'Dio', 'Maestro E2E', 'Firebase Test Lab'].map((t) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
              <div class="font-mono text-[10px] tracking-wider uppercase" style="color: var(--color-text-tertiary);">
                <span style="color: var(--color-accent);">~50,000 lines</span> &nbsp;Dart &nbsp;&middot;&nbsp; iOS / Android &nbsp;&middot;&nbsp; ~170 test files
              </div>
            </div>
          </div>
        </div>

        <p class="text-center text-xs mt-6" style="color: var(--color-text-tertiary);">
          Both apps are in active development. Desktop pre-release builds available on request. Mobile public release timing TBD.
        </p>
      </div>
    </section>

    <!-- STACK PRICING -->
    <section class="section-padding" style="background: var(--color-surface-secondary);">
      <div class="container-max mx-auto">
        <div class="text-center mb-14">
          <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Pricing</p>
          <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">Technical preview now. Production licensing soon.</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-4xl mx-auto">
          {[
            {
              tier: 'Founding Access',
              price: 'Invite Only',
              period: '',
              description: 'Three founding seats. 90 days of unlimited inference on the same stack we use to ship Thornveil\'s products. Hand-selected previewers who shape the roadmap and lock in pricing when paid access opens.',
              features: [
                'Unlimited inference on Qwen3.5-122B (no metering)',
                'All 6 domain agents included',
                'OpenAI-compatible API endpoint',
                'Direct line to the builder',
                'Roadmap input',
                'Locked-in pricing when paid tiers open',
                'Your conversations are preserved — when you bring RigRun in-house, your local copy ships pre-trained on your own usage',
              ],
              cta: 'Apply for Founding Access',
              featured: true,
              badge: '3 seats — Technical Preview',
            },
            {
              tier: 'RigRun License',
              price: 'TBD',
              period: '',
              description: 'Deploy on your own hardware. Your data never leaves your building. Pricing finalizes after the Founding Access program closes.',
              features: [
                'Full server binary + desktop app',
                'Unlimited local inference',
                '5-layer safety proxy + routing',
                'Self-training pipeline',
                'Agent Factory (unlimited agents)',
                'Self-regulating inference engine (7 autonomous optimization layers)',
                '1 year of updates + support',
              ],
              cta: 'Contact for Inquiries',
              featured: false,
              badge: 'Coming Soon',
            },
            {
              tier: 'Enterprise',
              price: 'Custom',
              period: '',
              description: 'Multi-node, classified environments, mesh networking.',
              features: [
                'Everything in RigRun License',
                'Mycelium mesh networking',
                'Classification routing (CUI–TS)',
                'On-premise installation support',
                'Custom agent development',
                'Dedicated technical support',
              ],
              cta: 'Contact Us',
              featured: false,
            },
          ].map((p, i) => (
            <div
              class={`reveal reveal-delay-${Math.min(i + 1, 4)} rounded-xl p-7 flex flex-col ${p.featured ? 'ring-1' : ''}`}
              style={`background: var(--color-surface-elevated); border: 1px solid ${p.featured ? 'var(--color-accent)' : 'var(--color-border)'}; ${p.featured ? `--tw-ring-color: var(--color-accent); box-shadow: 0 0 30px rgba(201, 168, 78, 0.08);` : ''}`}
            >
              {p.badge && (
                <span class="inline-block self-start font-mono text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full mb-4" style="background: var(--color-accent-muted); color: var(--color-accent);">
                  {p.badge}
                </span>
              )}
              <h3 class="text-lg font-semibold">{p.tier}</h3>
              <div class="mt-2 flex items-baseline gap-1">
                <span class="stat-number text-fluid-xl" style="color: var(--color-accent);">{p.price}</span>
                <span class="text-sm" style="color: var(--color-text-tertiary);">{p.period}</span>
              </div>
