---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Technology | Thornveil"
  description="RigRun sovereign AI infrastructure, Mycelium P2P mesh network, and Agent Factory meta-agent system. Built on a single GPU with 27 patents filed."
>
  <!-- HERO -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-max mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Technology</p>
      <h1 class="text-fluid-3xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">The stack</h1>
      <p class="text-base mt-4 max-w-2xl leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        Three interlocking systems that prove sovereign AI works today. One GPU, zero cloud dependency, 27 patents protecting the approach.
      </p>
    </div>
  </section>

  <!-- RIGRUN -->
  <section class="section-padding pt-12" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <div class="lg:col-span-3">
          <div class="flex items-center gap-3 mb-6 reveal">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-accent-muted); color: var(--color-accent); border: 1px solid var(--color-border);">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
            </div>
            <div>
              <h2 class="text-fluid-xl font-semibold tracking-tight">RigRun</h2>
              <span class="text-xs" style="color: var(--color-text-tertiary);">Single-Node Sovereign AI</span>
            </div>
          </div>

          <div class="space-y-4 text-sm leading-relaxed reveal reveal-delay-1" style="color: var(--color-text-secondary);">
            <p>Complete AI infrastructure running on one RTX PRO 6000 Blackwell (96GB VRAM). Qwen3.5-122B at 105 tok/s. The entire system operates with zero cloud dependency and $0 marginal inference cost.</p>
            <p>The system includes an autonomous ops center (Navigator) that manages 24 projects, a 5-layer safety stack with 94.86% adversarial block rate, and a zeroth-order training pipeline that improves the model overnight through the live inference API with zero downtime.</p>
          </div>

          <div class="mt-8 space-y-3 reveal reveal-delay-2">
            {[
              { label: 'TurboQuant KV Integration', detail: "Google's compression algorithm integrated into production serving. 5.2x KV cache compression, 99.92% quality retention. Per-request state pooling for batched inference." },
              { label: 'ZO2 Training Pipeline', detail: '10 preference loss functions, 8 zeroth-order techniques, cyclic LoRA rotation. 2,600 steps in 22 minutes. Trains through the live API without stopping inference.' },
              { label: '5-Layer Safety Stack', detail: 'Action gate, learned classifier, trajectory anomaly detection, declarative safety DSL, classification spillage detection. Defense in depth.' },
              { label: 'Dual-Model Cascade', detail: '35B generates at 184 tok/s, 122B reviews for quality. 7-stage router with entropy-based escalation. 93% routing accuracy across 15.8M tokens.' },
            ].map((item) => (
              <div class="rounded-lg p-4" style="border: 1px solid var(--color-border-subtle);">
                <div class="text-sm font-semibold mb-1">{item.label}</div>
                <div class="text-xs leading-relaxed" style="color: var(--color-text-tertiary);">{item.detail}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="lg:col-span-2 reveal reveal-delay-2">
          <div class="rounded-xl p-6" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border);">
            <h3 class="text-xs font-semibold tracking-wider uppercase mb-5" style="color: var(--color-text-tertiary);">Specs</h3>
            <div class="space-y-4">
              {[
                { label: 'Model', value: 'Qwen3.5-122B-A10B' },
                { label: 'Parameters', value: '397B total / 17B active (MoE)' },
                { label: 'Generation', value: '105 tok/s (122B)' },
                { label: 'Fast mode', value: '184 tok/s (35B)' },
                { label: 'Context', value: '65K tokens' },
                { label: 'KV Compression', value: '5.2x (TurboQuant)' },
                { label: 'VRAM', value: '96GB (98% utilized)' },
                { label: 'Hardware', value: 'RTX PRO 6000 Blackwell' },
                { label: 'Cost', value: '$16K one-time, $0/token' },
                { label: 'Patents', value: '10 filed (002-005, 010, 018-021, 023)' },
              ].map((s) => (
                <div class="flex justify-between items-baseline">
                  <span class="text-xs" style="color: var(--color-text-tertiary);">{s.label}</span>
                  <span class="font-mono text-xs font-medium">{s.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MYCELIUM -->
  <section class="section-padding">
    <div class="container-max mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <div class="lg:col-span-2 reveal reveal-delay-1 order-2 lg:order-1">
          <div class="rounded-xl p-6" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border);">
            <h3 class="text-xs font-semibold tracking-wider uppercase mb-5" style="color: var(--color-text-tertiary);">Device Tiers</h3>
            <div class="space-y-4">
              {[
                { tier: 'Phone', model: '0.6-1.7B', ram: '4-8GB', speed: '15-30 tok/s' },
                { tier: 'Laptop', model: '4-30B', ram: '8-32GB', speed: '10-40 tok/s' },
                { tier: 'Workstation', model: '30-72B', ram: '24-48GB', speed: '20-50 tok/s' },
                { tier: 'Server', model: '122B+', ram: '96GB+', speed: '105+ tok/s' },
                { tier: 'Cluster', model: '400B+ distributed', ram: 'Pooled', speed: 'Variable' },
              ].map((t) => (
                <div class="flex items-center gap-3 text-xs">
                  <span class="font-semibold w-20">{t.tier}</span>
                  <span class="font-mono flex-1" style="color: var(--color-text-tertiary);">{t.model}</span>
                  <span class="font-mono" style="color: var(--color-accent);">{t.speed}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-3 order-1 lg:order-2">
          <div class="flex items-center gap-3 mb-6 reveal">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-accent-muted); color: var(--color-accent); border: 1px solid var(--color-border);">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>
            </div>
            <div>
              <h2 class="text-fluid-xl font-semibold tracking-tight">Mycelium</h2>
              <span class="text-xs" style="color: var(--color-text-tertiary);">P2P AI Mesh Network</span>
            </div>
          </div>

          <div class="space-y-4 text-sm leading-relaxed reveal reveal-delay-1" style="color: var(--color-text-secondary);">
            <p>A peer-to-peer mesh that connects any device into a self-healing AI network. Phones, laptops, vehicles, servers. Works offline, degrades gracefully under load, and eliminates single points of failure.</p>
            <p>Three patented innovations make distributed AI work over consumer networks where conventional wisdom says you need InfiniBand.</p>
          </div>

          <div class="mt-8 space-y-3 reveal reveal-delay-2">
            {[
              { label: 'Distributed MoE over Consumer TCP', detail: 'MoE models activate only 3% of experts per token. Hidden state transfer is 6KB. Predictive prefetching hides latency inside the attention compute window. Lab-measured p50: 0.5ms over WiFi.' },
              { label: 'Proof-of-Inference without TEE', detail: 'Software-only trust verification: behavioral fingerprinting (pop quizzes), Merkle execution traces (show your work), economic reputation (cheating never pays). No special hardware chips required. Designed for mesh environments where some nodes may be untrusted — prevents a compromised or lazy node from returning fabricated responses instead of running actual inference.' },
              { label: 'Style Consistency Across Model Tiers', detail: 'A 0.6B phone model and a 122B server model answering together. Output normalization ensures the user cannot tell which device answered.' },
              { label: 'Classification-Aware Routing', detail: 'UNCLASSIFIED routes anywhere. CUI stays on-mesh. SECRET never leaves the device. Classification is metadata on every query, enforced at the routing layer.' },
            ].map((item) => (
              <div class="rounded-lg p-4" style="border: 1px solid var(--color-border-subtle);">
                <div class="text-sm font-semibold mb-1">{item.label}</div>
                <div class="text-xs leading-relaxed" style="color: var(--color-text-tertiary);">{item.detail}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AGENT FACTORY -->
  <section class="section-padding" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto max-w-3xl">
      <div class="flex items-center gap-3 mb-6 reveal">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-accent-muted); color: var(--color-accent); border: 1px solid var(--color-border);">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-5.1m0 0L11.42 4.97m-5.1 5.1H20.4" /></svg>
        </div>
        <div>
          <h2 class="text-fluid-xl font-semibold tracking-tight">Agent Factory</h2>
          <span class="text-xs" style="color: var(--color-text-tertiary);">AI That Builds AI Agents</span>
        </div>
      </div>

      <div class="space-y-4 text-sm leading-relaxed reveal reveal-delay-1" style="color: var(--color-text-secondary);">
        <p>Describe what you need in plain English. The factory decomposes requirements, generates a multi-pass system prompt with independent critique, selects tools, assembles a RAG knowledge base, generates few-shot examples, runs adversarial stress tests, calibrates against Claude Opus, and deploys through a human approval gate.</p>
        <p>Currently producing 6 domain expert agents averaging 9/10 quality scores. Each agent has 7-11 tools, 2+ few-shot examples, and structured evaluation rubrics. The factory's output improves over time as agents generate DPO training pairs from production usage.</p>
      </div>

      <div class="mt-8 reveal reveal-delay-2">
        <a href="/products" class="btn-primary text-sm">
          See the agents &rarr;
        </a>
      </div>

      <div class="divider my-12 reveal reveal-delay-3"></div>

      <div class="grid grid-cols-3 gap-8 text-center reveal reveal-delay-3">
        <div>
          <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">14</div>
          <div class="text-xs mt-1" style="color: var(--color-text-tertiary);">Pipeline<br/>steps</div>
        </div>
        <div>
          <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">12</div>
          <div class="text-xs mt-1" style="color: var(--color-text-tertiary);">Tools in<br/>registry</div>
        </div>
        <div>
          <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">5</div>
          <div class="text-xs mt-1" style="color: var(--color-text-tertiary);">Adversarial<br/>probes</div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPLIANCE -->
  <section class="section-padding" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <div class="mb-14 text-center">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Compliance
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          Security & Compliance
        </h2>
        <p class="text-sm mt-4 max-w-xl mx-auto leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
          Controls implemented. Certification in progress.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Implemented Controls -->
        <div class="card-gradient-border p-7 reveal reveal-delay-1">
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-accent-muted); color: var(--color-accent); border: 1px solid var(--color-border);">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
              </div>
              <h3 class="text-base font-semibold tracking-tight">Implemented Controls</h3>
            </div>

            <div class="mb-5">
              <h4 class="text-xs font-semibold tracking-wider uppercase mb-3" style="color: var(--color-text-tertiary);">NIST 800-53 Rev 5</h4>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {[
                  'AC-2 Account Management',
                  'AC-4 Information Flow',
                  'AU-2 Audit Events',
                  'AU-9 Audit Protection',
                  'IA-2 Multi-Factor Auth',
                  'IA-5 Authenticator Mgmt',
                  'IR-4 Incident Handling',
                  'SC-8 Transmission Confidentiality',
                  'SC-13 Cryptographic Protection',
                  'SC-28 Data at Rest',
                  'PS-6 Access Agreements',
                ].map((ctrl) => (
                  <div class="flex items-center gap-2 text-xs" style="color: var(--color-text-secondary);">
                    <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: var(--color-accent);"></span>
                    {ctrl}
                  </div>
                ))}
              </div>
            </div>

            <div class="space-y-2 mt-5">
              {[
                'Classification enforcement (UNCLASS through TS)',
                'AES-256-GCM encryption at rest with PBKDF2 key derivation',
                'HMAC-chained audit logs with tamper detection',
                'JWT/OAuth/OIDC authentication with MFA (TOTP)',
              ].map((item) => (
                <div class="flex items-start gap-2 text-xs" style="color: var(--color-text-secondary);">
                  <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 mt-1" style="background: var(--color-accent);"></span>
                  {item}
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Certification Roadmap -->
        <div class="card-gradient-border p-7 reveal reveal-delay-2">
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-accent-muted); color: var(--color-accent); border: 1px solid var(--color-border);">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" /></svg>
              </div>
              <h3 class="text-base font-semibold tracking-tight">Certification Roadmap</h3>
            </div>

            <div class="space-y-4">
              {[
                { cert: 'SOC 2 Type II', status: 'In planning', color: '#f97316' },
                { cert: 'CMMC Level 2', status: 'Controls implemented, assessment pending', color: '#3b82f6' },
                { cert: 'FedRAMP', status: 'Not yet pursued (requires sponsoring agency)', color: '#6b7280' },
                { cert: 'ATO', status: 'SSP in development, pen test pending', color: '#f97316' },
                { cert: 'FIPS 140-3', status: 'Runtime verification implemented, formal validation pending', color: '#3b82f6' },
              ].map((item) => (
                <div class="rounded-lg p-4" style="border: 1px solid var(--color-border-subtle);">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-sm font-semibold">{item.cert}</span>
                    <span class="w-2 h-2 rounded-full" style={`background: ${item.color};`}></span>
                  </div>
                  <div class="text-xs" style="color: var(--color-text-tertiary);">{item.status}</div>
                </div>
              ))}
            </div>

            <div class="mt-6 rounded-lg p-4" style="border: 1px solid var(--color-border-subtle); background: var(--color-surface-elevated);">
              <p class="text-xs leading-relaxed" style="color: var(--color-text-tertiary);">
                We are transparent about what we have and what we're working toward. No certification is claimed until formally granted.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  const lenis = new Lenis({ duration: 1.2, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
  function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);
</script>
