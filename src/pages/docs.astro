---
import BaseLayout from '../layouts/BaseLayout.astro';

const rigrunEndpoints = [
  { method: 'POST', path: '/v1/chat/completions', description: 'Chat inference (OpenAI-compatible)' },
  { method: 'POST', path: '/v1/messages', description: 'Chat inference (Anthropic-compatible)' },
  { method: 'GET', path: '/v1/models', description: 'List available models' },
  { method: 'POST', path: '/v1/audio/transcribe', description: 'Audio transcription' },
  { method: 'POST', path: '/v1/tools/{name}/execute', description: 'Tool execution with approval handshake' },
  { method: 'GET', path: '/v1/memory/search', description: 'Semantic memory search' },
  { method: 'POST', path: '/v1/research/sessions', description: 'Agentic research session (4-phase A-RAG)' },
  { method: 'GET', path: '/metrics', description: 'Prometheus-format metrics' },
];

const pyrosEndpoints = [
  { method: 'GET', path: '/v1/health', description: 'Engine health + backend probe' },
  { method: 'GET', path: '/v1/layers', description: 'Pillar status and per-layer state' },
  { method: 'GET', path: '/v1/stats', description: 'Engine statistics, vitals, throughput' },
  { method: 'GET', path: '/v1/signals', description: 'Active signal blackboard (gate signals)' },
  { method: 'GET', path: '/v1/breakers', description: 'Circuit breaker states' },
  { method: 'GET', path: '/metrics', description: 'Prometheus-format metrics' },
];

const rollingMemoryEndpoints = [
  { method: 'POST', path: '/v1/chat/completions', description: 'OpenAI-compatible chat with infinite context' },
  { method: 'POST', path: '/v1/messages', description: 'Anthropic-compatible chat with infinite context' },
  { method: 'GET', path: '/memory/session/{id}/summaries', description: 'Per-session summary tier' },
  { method: 'GET', path: '/memory/session/{id}/export', description: 'Export full session for training/audit' },
  { method: 'DELETE', path: '/memory/session/{id}', description: 'Wipe a session (cache + disk)' },
  { method: 'GET', path: '/memory/ui', description: 'Live dashboard with semantic search' },
  { method: 'GET', path: '/search', description: 'Built-in web search (SearxNG-backed)' },
];

const configSections = [
  { key: '[routing]', fields: 'default_mode, max_tier, paranoid_mode, offline_mode', description: 'Controls how requests are routed between local models and optional cloud fallback. Set offline_mode = true to enforce zero external traffic. paranoid_mode enables full request/response auditing.' },
  { key: '[local]', fields: 'ollama_url, ollama_model', description: 'Points to your local inference backend. Supports Ollama, llama.cpp (OpenAI-compatible server), and vLLM. The model name here is what the router resolves when a request arrives.' },
  { key: '[cloud]', fields: 'openrouter_key, default_model', description: 'Optional cloud fallback for when local inference is unavailable or the request exceeds local model capability. Disabled by default. Only activates if explicitly configured and offline_mode is false.' },
  { key: '[security]', fields: 'classification, audit_enabled, session_timeout, mfa', description: 'Set the baseline classification level (UNCLASSIFIED, CUI, SECRET). When audit_enabled is true, every request and response is logged to an append-only audit trail. MFA gates the desktop app and API key management.' },
  { key: '[training]', fields: 'enabled, schedule, methods, scoring', description: 'Controls the self-improving overnight pipeline. Schedule accepts cron syntax. 11 training methods supported (DPO, SimPO, ORPO, KTO, CPO, GRPO, IPO, SPPO, RPO, AERO, iterative DPO-VP) plus ZO2 Ultimate (zeroth-order optimization with 12 advanced techniques: sparse MeZO, HiZOO Hessian, curriculum, cosine epsilon annealing, cross-night EMA, etc.). Pairs are dual-sourced from rolling-memory and legacy sessions, scored by a Skywork reward model (runs locally, no external service dependency) + a sandboxed CodeRL+ execution scorer + the 122B itself as judge.' },
];

const pyrosPillars = [
  { num: 'I', name: 'Oracle', description: 'Predictive intel — UCB1 cascade routing, gate signals to skip easy work' },
  { num: 'II', name: 'Tribunal', description: 'Adversarial verification — 6-feature hallucination probe, courtroom debate' },
  { num: 'III', name: 'Fortress', description: 'Pre-inference defense — prompt injection blocks at conf ≥ 0.7, SmoothLLM, AIS detectors' },
  { num: 'IV', name: 'MindEye', description: 'Metacognition — knowledge graph injection, isotonic calibration, QualityScore' },
  { num: 'V', name: 'Forge', description: 'Self-improvement — EvoPrompt evolution, MDL prompt compression, DICE exemplar capture' },
  { num: 'VI', name: 'Crucible', description: 'Operational safety — circuit breakers, OTel spans, stigmergic blackboard' },
  { num: 'VII', name: 'Singularity', description: 'Homeostatic regulation — PID over runtime vitals, superposition, digital twin' },
  { num: '⊕', name: 'LLM Inference', description: 'Token generation via the configured backend (RigRun, vLLM, llama.cpp, OpenAI, Anthropic)' },
];

const services = [
  { port: '8787', name: 'RigRun', detail: 'Go server: chat, tools, research, memory, audio, training control' },
  { port: '3100', name: 'Pyros', detail: 'Pure-Go safety engine: 7-pillar pipeline, optional but recommended' },
  { port: '8096', name: 'Rolling Memory', detail: 'Infinite-context proxy: speaks OpenAI + Anthropic, per-session disk store' },
  { port: '8081', name: 'llama-embed', detail: 'CPU embedding service (Qwen3-Embedding-4B)' },
  { port: '8082', name: 'llama-rerank', detail: 'CPU reranker (Qwen3-Reranker-0.6B)' },
  { port: '8083', name: 'llama-classify', detail: 'CPU classifier for routing (Qwen3-0.6B)' },
  { port: '8084', name: 'vision', detail: 'Vision model (Qwen3-VL-4B), idle-unloaded to free VRAM' },
];

const agentConcepts = [
  { label: 'System prompt synthesis', detail: 'Multi-pass generation with independent critique. A second model reviews and hardens the prompt before deployment.' },
  { label: 'Tool selection from typed registry', detail: 'The factory auto-selects from a typed tool registry based on the agent\'s domain requirements. Each tool has input/output schemas and usage examples.' },
  { label: 'Knowledge base assembly', detail: 'Vector store with semantic chunking. Documents are ingested, chunked by semantic boundaries (not token count), embedded, and indexed in ChromaDB.' },
  { label: 'Adversarial stress testing', detail: 'Five probe types: prompt injection, hallucination induction, scope violation, confidentiality extraction, and output format corruption.' },
  { label: 'Quality gate', detail: 'Human approval required before any agent goes live. Automated scoring checks 100% happy-path pass rate and 50% edge-case pass rate minimum.' },
];
---

<BaseLayout
  title="Documentation | Thornveil"
  description="RigRun documentation. System requirements, API reference, configuration, architecture, and agent development. Everything you need to deploy, configure, and integrate."
>
  <!-- HERO -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-max mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Documentation</p>
      <h1 class="text-fluid-3xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">Get started with RigRun</h1>
      <p class="text-base mt-4 max-w-2xl leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        Everything you need to deploy, configure, and integrate.
      </p>
    </div>
  </section>

  <!-- QUICK START -->
  <section class="section-padding pt-12">
    <div class="container-max mx-auto">
      <div class="mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Quick Start
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          Up and running in three steps
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="reveal reveal-delay-1 card-gradient-border p-7" data-tilt>
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="font-mono text-lg font-bold" style="color: var(--color-accent);">01</span>
              <h3 class="text-base font-semibold tracking-tight">System Requirements</h3>
            </div>
            <div class="space-y-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              <div>
                <span class="text-xs font-semibold tracking-wider uppercase block mb-1" style="color: var(--color-text-tertiary);">Minimum (small models)</span>
                <p>NVIDIA GPU with 24GB+ VRAM, 64GB system RAM, Ubuntu 22.04+, RHEL 8+ / Rocky Linux 8+, or Windows 11.</p>
              </div>
              <div>
                <span class="text-xs font-semibold tracking-wider uppercase block mb-1" style="color: var(--color-text-tertiary);">Recommended (122B model + KV compression)</span>
                <p>RTX PRO 6000 Blackwell (96GB), 128GB RAM, Ubuntu 24.04.</p>
              </div>
              <div class="flex flex-wrap gap-1.5 pt-1">
                <span class="tag">vLLM</span>
                <span class="tag">llama.cpp</span>
                <span class="tag">Ollama</span>
              </div>
            </div>
          </div>
        </div>

        <div class="reveal reveal-delay-2 card-gradient-border p-7" data-tilt>
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="font-mono text-lg font-bold" style="color: var(--color-accent);">02</span>
              <h3 class="text-base font-semibold tracking-tight">Installation</h3>
            </div>
            <div class="space-y-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              <p>Single static binary. Download, configure <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background: var(--color-surface-secondary); color: var(--color-accent);">config.toml</code>, run. No Docker required for base deployment. Docker is used optionally for the code-interpreter sandbox.</p>
              <p>Companion apps available: <a href="/products" style="color: var(--color-accent); text-decoration: underline;">RigRun Desktop</a> (Electron, pre-release) and RigRun Mobile (Flutter, not yet released).</p>
              <div class="rounded-lg p-3 mt-2" style="background: var(--color-surface-secondary); border: 1px solid var(--color-border-subtle);">
                <code class="font-mono text-xs block" style="color: var(--color-text-secondary);">
                  <span style="color: var(--color-text-tertiary);">$</span> ./rigrun serve
                </code>
              </div>
            </div>
          </div>
        </div>

        <div class="reveal reveal-delay-3 card-gradient-border p-7" data-tilt>
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="font-mono text-lg font-bold" style="color: var(--color-accent);">03</span>
              <h3 class="text-base font-semibold tracking-tight">First Query</h3>
            </div>
            <div class="space-y-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              <p>OpenAI-compatible API at <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background: var(--color-surface-secondary); color: var(--color-accent);">/v1/chat/completions</code>.</p>
              <p>Drop-in replacement — change your base URL, keep your existing code. Supports streaming (SSE), tool calling, and structured output.</p>
              <div class="flex flex-wrap gap-1.5 pt-1">
                <span class="tag">SSE Streaming</span>
                <span class="tag">Tool Calling</span>
                <span class="tag">Structured Output</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE TOPOLOGY -->
  <section class="section-padding pt-12">
    <div class="container-max mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Topology</p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">What's running on the box</h2>
        <p class="text-sm mt-3 max-w-2xl reveal reveal-delay-2" style="color: var(--color-text-secondary);">
          A full RigRun deployment is several cooperating services on different ports. The Go server is the front door; the rest are optional but recommended. Auxiliary models run on CPU to keep VRAM free for the main inference engine.
        </p>
      </div>

      <div class="rounded-xl overflow-hidden reveal reveal-delay-2" style="border: 1px solid var(--color-border);">
        {services.map((s, i) => (
          <div class="grid grid-cols-12 items-center gap-3 px-5 py-3" style={`background: var(--color-surface-elevated); ${i < services.length - 1 ? 'border-bottom: 1px solid var(--color-border-subtle);' : ''}`}>
            <code class="col-span-2 md:col-span-1 font-mono text-xs font-bold" style="color: var(--color-accent);">:{s.port}</code>
            <div class="col-span-3 md:col-span-2 text-sm font-semibold">{s.name}</div>
            <div class="col-span-7 md:col-span-9 text-xs" style="color: var(--color-text-tertiary);">{s.detail}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ROLLING MEMORY -->
  <section class="section-padding pt-12">
    <div class="container-max mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Memory layer</p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">Rolling Memory v4 — infinite context proxy</h2>
        <p class="text-sm mt-3 max-w-3xl reveal reveal-delay-2" style="color: var(--color-text-secondary);">
          A drop-in OpenAI/Anthropic-compatible reverse proxy on port 8096 that gives any LLM effectively unlimited context via per-session disk-backed verbatim, summary, and embedding tiers. Latency stays flat with depth because retrieval keeps each forward pass roughly the same size regardless of total context length.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8 reveal reveal-delay-3">
        {[
          { value: '10M', label: 'Characters tested' },
          { value: '2.5M', label: 'Tokens tested' },
          { value: '100%', label: 'Needle recall' },
          { value: '~10s', label: 'Latency at depth' },
        ].map((m) => (
          <div class="rounded-lg p-3 text-center" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border);">
            <div class="font-mono text-base font-bold" style="color: var(--color-accent);">{m.value}</div>
            <div class="font-mono text-[9px] tracking-wider uppercase mt-1" style="color: var(--color-text-tertiary);">{m.label}</div>
          </div>
        ))}
      </div>

      <p class="text-xs leading-relaxed mb-6" style="color: var(--color-text-tertiary);">
        Verified 2026-04-11: needle-in-haystack 100% pass through 10M chars (8.9–9.1s), 5/5 fact consistency, 10/10 multi-turn retrieval, 17/17 smoke tests passed. Includes per-CWD session isolation, dashboard at /memory/ui, Prometheus metrics, and a built-in /search endpoint backed by SearxNG.
      </p>
    </div>
  </section>

  <!-- API REFERENCE -->
  <section class="section-padding" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <div class="mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Reference
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          API Reference
        </h2>
        <p class="text-sm mt-3 max-w-2xl reveal reveal-delay-2" style="color: var(--color-text-secondary);">
          Endpoints listen on different ports per service. Authentication via <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background: var(--color-surface); color: var(--color-accent);">Authorization: Bearer</code> header. RigRun has ~260 routes total — selected groups shown below.
        </p>
      </div>

      <!-- RigRun endpoints -->
      <div class="card-gradient-border p-7 reveal reveal-delay-2 mb-5">
        <div class="relative z-10">
          <div class="flex items-baseline justify-between mb-5 flex-wrap gap-2">
            <h3 class="text-sm font-semibold tracking-wider uppercase" style="color: var(--color-text-tertiary);">RigRun</h3>
            <code class="font-mono text-xs" style="color: var(--color-accent);">http://localhost:8787</code>
          </div>
          <div class="space-y-0">
            {rigrunEndpoints.map((ep, i) => (
              <div class="flex items-center gap-4 py-3" style={`${i < rigrunEndpoints.length - 1 ? 'border-bottom: 1px solid var(--color-border-subtle);' : ''}`}>
                <span class="font-mono text-[10px] font-bold tracking-wider w-16 text-center py-0.5 rounded flex-shrink-0" style={`color: ${ep.method === 'POST' ? '#10b981' : ep.method === 'DELETE' ? '#ef4444' : '#3b82f6'}; background: ${ep.method === 'POST' ? 'rgba(16, 185, 129, 0.1)' : ep.method === 'DELETE' ? 'rgba(239, 68, 68, 0.1)' : 'rgba(59, 130, 246, 0.1)'}; border: 1px solid ${ep.method === 'POST' ? 'rgba(16, 185, 129, 0.2)' : ep.method === 'DELETE' ? 'rgba(239, 68, 68, 0.2)' : 'rgba(59, 130, 246, 0.2)'};`}>
                  {ep.method}
                </span>
                <code class="font-mono text-xs md:text-sm flex-shrink-0 truncate" style="color: var(--color-text-primary);">{ep.path}</code>
                <span class="text-xs md:text-sm flex-1 text-right md:text-left" style="color: var(--color-text-tertiary);">{ep.description}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Pyros endpoints -->
      <div class="card-gradient-border p-7 reveal reveal-delay-3 mb-5">
        <div class="relative z-10">
          <div class="flex items-baseline justify-between mb-5 flex-wrap gap-2">
            <h3 class="text-sm font-semibold tracking-wider uppercase" style="color: var(--color-text-tertiary);">Pyros Safety Engine</h3>
            <code class="font-mono text-xs" style="color: var(--color-accent);">http://localhost:3100</code>
          </div>
          <div class="space-y-0">
            {pyrosEndpoints.map((ep, i) => (
              <div class="flex items-center gap-4 py-3" style={`${i < pyrosEndpoints.length - 1 ? 'border-bottom: 1px solid var(--color-border-subtle);' : ''}`}>
                <span class="font-mono text-[10px] font-bold tracking-wider w-16 text-center py-0.5 rounded flex-shrink-0" style={`color: #3b82f6; background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.2);`}>
                  {ep.method}
                </span>
                <code class="font-mono text-xs md:text-sm flex-shrink-0 truncate" style="color: var(--color-text-primary);">{ep.path}</code>
                <span class="text-xs md:text-sm flex-1 text-right md:text-left" style="color: var(--color-text-tertiary);">{ep.description}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Rolling Memory endpoints -->
      <div class="card-gradient-border p-7 reveal reveal-delay-4">
        <div class="relative z-10">
          <div class="flex items-baseline justify-between mb-5 flex-wrap gap-2">
            <h3 class="text-sm font-semibold tracking-wider uppercase" style="color: var(--color-text-tertiary);">Rolling Memory v4</h3>
            <code class="font-mono text-xs" style="color: var(--color-accent);">http://localhost:8096</code>
          </div>
          <div class="space-y-0">
            {rollingMemoryEndpoints.map((ep, i) => (
              <div class="flex items-center gap-4 py-3" style={`${i < rollingMemoryEndpoints.length - 1 ? 'border-bottom: 1px solid var(--color-border-subtle);' : ''}`}>
                <span class="font-mono text-[10px] font-bold tracking-wider w-16 text-center py-0.5 rounded flex-shrink-0" style={`color: ${ep.method === 'POST' ? '#10b981' : ep.method === 'DELETE' ? '#ef4444' : '#3b82f6'}; background: ${ep.method === 'POST' ? 'rgba(16, 185, 129, 0.1)' : ep.method === 'DELETE' ? 'rgba(239, 68, 68, 0.1)' : 'rgba(59, 130, 246, 0.1)'}; border: 1px solid ${ep.method === 'POST' ? 'rgba(16, 185, 129, 0.2)' : ep.method === 'DELETE' ? 'rgba(239, 68, 68, 0.2)' : 'rgba(59, 130, 246, 0.2)'};`}>
                  {ep.method}
                </span>
                <code class="font-mono text-xs md:text-sm flex-shrink-0 truncate" style="color: var(--color-text-primary);">{ep.path}</code>
                <span class="text-xs md:text-sm flex-1 text-right md:text-left" style="color: var(--color-text-tertiary);">{ep.description}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Curl Example -->
      <div class="mt-8 reveal reveal-delay-3">
        <h3 class="text-sm font-semibold tracking-wider uppercase mb-4" style="color: var(--color-text-tertiary);">Example Request</h3>
        <div class="rounded-xl overflow-hidden" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border);">
          <div class="flex items-center justify-between px-5 py-3" style="border-bottom: 1px solid var(--color-border-subtle);">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style="background: #10b981;"></span>
              <span class="font-mono text-[10px] tracking-wider uppercase" style="color: var(--color-text-tertiary);">bash</span>
            </div>
            <span class="font-mono text-[10px] tracking-wider" style="color: var(--color-text-tertiary);">Streaming chat completion</span>
          </div>
          <pre class="px-5 py-5 overflow-x-auto"><code class="font-mono text-sm leading-relaxed" style="color: var(--color-text-secondary);">curl http://localhost:8787/v1/chat/completions \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $RIGRUN_API_KEY" \
  -d '&#123;
    "model": "default",
    "messages": [&#123;"role": "user", "content": "Hello"&#125;],
    "stream": true
  &#125;'</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- CONFIGURATION -->
  <section class="section-padding">
    <div class="container-max mx-auto">
      <div class="mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Setup
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          Configuration
        </h2>
        <p class="text-sm mt-3 max-w-2xl reveal reveal-delay-2" style="color: var(--color-text-secondary);">
          All configuration lives in a single <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background: var(--color-surface-secondary); color: var(--color-accent);">config.toml</code> file. Sensible defaults ship out of the box — most deployments only need to set the local backend URL and model name.
        </p>
      </div>

      <div class="space-y-4">
        {configSections.map((section, i) => (
          <div class={`reveal reveal-delay-${Math.min(i + 1, 4)} rounded-xl p-6`} style="background: var(--color-surface-elevated); border: 1px solid var(--color-border);">
            <div class="flex items-start gap-4">
              <code class="font-mono text-sm font-bold flex-shrink-0 py-0.5" style="color: var(--color-accent);">{section.key}</code>
              <div class="flex-1 min-w-0">
                <div class="font-mono text-xs mb-2 flex flex-wrap gap-1.5">
                  {section.fields.split(', ').map((field: string) => (
                    <span class="px-2 py-0.5 rounded" style="background: var(--color-surface-secondary); color: var(--color-text-secondary); border: 1px solid var(--color-border-subtle);">{field}</span>
                  ))}
                </div>
                <p class="text-sm leading-relaxed" style="color: var(--color-text-tertiary);">{section.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ARCHITECTURE -->
  <section class="section-padding" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <div class="mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Internals
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          Pyros pipeline architecture
        </h2>
