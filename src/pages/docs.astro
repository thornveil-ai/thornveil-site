---
import BaseLayout from '../layouts/BaseLayout.astro';

const endpoints = [
  { method: 'POST', path: '/v1/chat/completions', description: 'Chat inference (OpenAI-compatible)' },
  { method: 'POST', path: '/v1/messages', description: 'Chat inference (Anthropic-compatible)' },
  { method: 'GET', path: '/v1/models', description: 'List available models' },
  { method: 'GET', path: '/v1/health', description: 'Server health + backend probe' },
  { method: 'GET', path: '/v1/layers', description: 'Pipeline layer status (Pyros)' },
  { method: 'GET', path: '/v1/stats', description: 'Engine statistics' },
  { method: 'GET', path: '/v1/signals', description: 'Active signal blackboard' },
  { method: 'GET', path: '/v1/breakers', description: 'Circuit breaker states' },
  { method: 'GET', path: '/metrics', description: 'Prometheus-format metrics' },
];

const configSections = [
  { key: '[routing]', fields: 'default_mode, max_tier, paranoid_mode, offline_mode', description: 'Controls how requests are routed between local models and optional cloud fallback. Set offline_mode = true to guarantee zero external traffic. paranoid_mode enables full request/response auditing.' },
  { key: '[local]', fields: 'ollama_url, ollama_model', description: 'Points to your local inference backend. Supports Ollama, llama.cpp (OpenAI-compatible server), and vLLM. The model name here is what the router resolves when a request arrives.' },
  { key: '[cloud]', fields: 'openrouter_key, default_model', description: 'Optional cloud fallback for when local inference is unavailable or the request exceeds local model capability. Disabled by default. Only activates if explicitly configured and offline_mode is false.' },
  { key: '[security]', fields: 'classification, audit_enabled, session_timeout, mfa', description: 'Set the baseline classification level (UNCLASSIFIED, CUI, SECRET). When audit_enabled is true, every request and response is logged to an append-only audit trail. MFA gates the desktop app and API key management.' },
  { key: '[training]', fields: 'enabled, schedule, methods', description: 'Controls the self-improving training pipeline. Schedule accepts cron syntax. Methods include DPO (direct preference optimization) and SimPO (simple preference optimization). Training runs through the live inference API with zero downtime.' },
];

const pipelineLayers = [
  { name: 'Auth', description: 'API key validation, rate limiting, session binding' },
  { name: 'Crucible', description: 'Distributed tracing, request tagging, latency instrumentation' },
  { name: 'Fortress', description: 'Safety classification, prompt injection detection, action gating' },
  { name: 'Oracle', description: 'Model routing, cascade decisions, entropy-based escalation' },
  { name: 'Singularity', description: 'PID controller for throughput/latency balance, adaptive batching' },
  { name: 'Forge', description: 'KV cache optimization, TurboQuant compression, prompt compaction' },
  { name: "Mind's Eye", description: 'RAG retrieval, knowledge base injection, context assembly' },
  { name: 'LLM Inference', description: 'Token generation via configured backend' },
];

const agentConcepts = [
  { label: 'System prompt synthesis', detail: 'Multi-pass generation with independent critique. A second model reviews and hardens the prompt before deployment.' },
  { label: 'Tool selection from typed registry', detail: 'The factory auto-selects from a typed tool registry based on the agent\'s domain requirements. Each tool has input/output schemas and usage examples.' },
  { label: 'Knowledge base assembly', detail: 'Vector store with semantic chunking. Documents are ingested, chunked by semantic boundaries (not token count), embedded, and indexed in ChromaDB.' },
  { label: 'Adversarial stress testing', detail: 'Five probe types: prompt injection, hallucination induction, scope violation, confidentiality extraction, and output format corruption.' },
  { label: 'Quality gate', detail: 'Human approval required before any agent goes live. Automated scoring checks 100% happy-path pass rate and 50% edge-case pass rate minimum.' },
];
---

<BaseLayout
  title="Documentation | Thornveil"
  description="RigRun documentation. System requirements, API reference, configuration, architecture, and agent development. Everything you need to deploy, configure, and integrate."
>
  <!-- HERO -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-max mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Documentation</p>
      <h1 class="text-fluid-3xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">Get started with RigRun</h1>
      <p class="text-base mt-4 max-w-2xl leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        Everything you need to deploy, configure, and integrate.
      </p>
    </div>
  </section>

  <!-- QUICK START -->
  <section class="section-padding pt-12">
    <div class="container-max mx-auto">
      <div class="mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Quick Start
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          Up and running in three steps
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="reveal reveal-delay-1 card-gradient-border p-7" data-tilt>
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="font-mono text-lg font-bold" style="color: var(--color-accent);">01</span>
              <h3 class="text-base font-semibold tracking-tight">System Requirements</h3>
            </div>
            <div class="space-y-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              <div>
                <span class="text-xs font-semibold tracking-wider uppercase block mb-1" style="color: var(--color-text-tertiary);">Minimum</span>
                <p>NVIDIA GPU with 24GB+ VRAM, 64GB system RAM, Ubuntu 22.04+ or Windows 11.</p>
              </div>
              <div>
                <span class="text-xs font-semibold tracking-wider uppercase block mb-1" style="color: var(--color-text-tertiary);">Recommended</span>
                <p>RTX 4090 / A6000 / PRO 6000, 128GB RAM.</p>
              </div>
              <div class="flex flex-wrap gap-1.5 pt-1">
                <span class="tag">Ollama</span>
                <span class="tag">llama.cpp</span>
                <span class="tag">vLLM</span>
              </div>
            </div>
          </div>
        </div>

        <div class="reveal reveal-delay-2 card-gradient-border p-7" data-tilt>
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="font-mono text-lg font-bold" style="color: var(--color-accent);">02</span>
              <h3 class="text-base font-semibold tracking-tight">Installation</h3>
            </div>
            <div class="space-y-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              <p>Single binary deployment. Download, configure <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background: var(--color-surface-secondary); color: var(--color-accent);">config.toml</code>, run.</p>
              <p>Ships with a desktop app (Electron) for GUI management. No Docker required, no build step.</p>
              <div class="rounded-lg p-3 mt-2" style="background: var(--color-surface-secondary); border: 1px solid var(--color-border-subtle);">
                <code class="font-mono text-xs block" style="color: var(--color-text-secondary);">
                  <span style="color: var(--color-text-tertiary);">$</span> ./rigrun serve
                </code>
              </div>
            </div>
          </div>
        </div>

        <div class="reveal reveal-delay-3 card-gradient-border p-7" data-tilt>
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="font-mono text-lg font-bold" style="color: var(--color-accent);">03</span>
              <h3 class="text-base font-semibold tracking-tight">First Query</h3>
            </div>
            <div class="space-y-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              <p>OpenAI-compatible API at <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background: var(--color-surface-secondary); color: var(--color-accent);">/v1/chat/completions</code>.</p>
              <p>Drop-in replacement — change your base URL, keep your existing code. Supports streaming (SSE), tool calling, and structured output.</p>
              <div class="flex flex-wrap gap-1.5 pt-1">
                <span class="tag">SSE Streaming</span>
                <span class="tag">Tool Calling</span>
                <span class="tag">Structured Output</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- API REFERENCE -->
  <section class="section-padding" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <div class="mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Reference
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          API Reference
        </h2>
        <p class="text-sm mt-3 max-w-2xl reveal reveal-delay-2" style="color: var(--color-text-secondary);">
          All endpoints listen on <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background: var(--color-surface); color: var(--color-accent);">http://localhost:8787</code> by default. Authentication via <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background: var(--color-surface); color: var(--color-accent);">Authorization: Bearer</code> header.
        </p>
      </div>

      <!-- Endpoints Table -->
      <div class="card-gradient-border p-7 reveal reveal-delay-2">
        <div class="relative z-10">
          <h3 class="text-sm font-semibold tracking-wider uppercase mb-5" style="color: var(--color-text-tertiary);">Endpoints</h3>
          <div class="space-y-0">
            {endpoints.map((ep, i) => (
              <div
                class="flex items-center gap-4 py-3"
                style={`${i < endpoints.length - 1 ? 'border-bottom: 1px solid var(--color-border-subtle);' : ''}`}
              >
                <span
                  class={`font-mono text-[10px] font-bold tracking-wider w-12 text-center py-0.5 rounded flex-shrink-0 ${ep.method === 'POST' ? '' : ''}`}
                  style={`color: ${ep.method === 'POST' ? '#10b981' : '#3b82f6'}; background: ${ep.method === 'POST' ? 'rgba(16, 185, 129, 0.1)' : 'rgba(59, 130, 246, 0.1)'}; border: 1px solid ${ep.method === 'POST' ? 'rgba(16, 185, 129, 0.2)' : 'rgba(59, 130, 246, 0.2)'};`}
                >
                  {ep.method}
                </span>
                <code class="font-mono text-sm flex-shrink-0" style="color: var(--color-text-primary);">{ep.path}</code>
                <span class="text-sm flex-1 text-right md:text-left" style="color: var(--color-text-tertiary);">{ep.description}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Curl Example -->
      <div class="mt-8 reveal reveal-delay-3">
        <h3 class="text-sm font-semibold tracking-wider uppercase mb-4" style="color: var(--color-text-tertiary);">Example Request</h3>
        <div class="rounded-xl overflow-hidden" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border);">
          <div class="flex items-center justify-between px-5 py-3" style="border-bottom: 1px solid var(--color-border-subtle);">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style="background: #10b981;"></span>
              <span class="font-mono text-[10px] tracking-wider uppercase" style="color: var(--color-text-tertiary);">bash</span>
            </div>
            <span class="font-mono text-[10px] tracking-wider" style="color: var(--color-text-tertiary);">Streaming chat completion</span>
          </div>
          <pre class="px-5 py-5 overflow-x-auto"><code class="font-mono text-sm leading-relaxed" style="color: var(--color-text-secondary);">curl http://localhost:8787/v1/chat/completions \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $RIGRUN_API_KEY" \
  -d '&#123;
    "model": "default",
    "messages": [&#123;"role": "user", "content": "Hello"&#125;],
    "stream": true
  &#125;'</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- CONFIGURATION -->
  <section class="section-padding">
    <div class="container-max mx-auto">
      <div class="mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Setup
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          Configuration
        </h2>
        <p class="text-sm mt-3 max-w-2xl reveal reveal-delay-2" style="color: var(--color-text-secondary);">
          All configuration lives in a single <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background: var(--color-surface-secondary); color: var(--color-accent);">config.toml</code> file. Sensible defaults ship out of the box — most deployments only need to set the local backend URL and model name.
        </p>
      </div>

      <div class="space-y-4">
        {configSections.map((section, i) => (
          <div class={`reveal reveal-delay-${Math.min(i + 1, 4)} rounded-xl p-6`} style="background: var(--color-surface-elevated); border: 1px solid var(--color-border);">
            <div class="flex items-start gap-4">
              <code class="font-mono text-sm font-bold flex-shrink-0 py-0.5" style="color: var(--color-accent);">{section.key}</code>
              <div class="flex-1 min-w-0">
                <div class="font-mono text-xs mb-2 flex flex-wrap gap-1.5">
                  {section.fields.split(', ').map((field: string) => (
                    <span class="px-2 py-0.5 rounded" style="background: var(--color-surface-secondary); color: var(--color-text-secondary); border: 1px solid var(--color-border-subtle);">{field}</span>
                  ))}
                </div>
                <p class="text-sm leading-relaxed" style="color: var(--color-text-tertiary);">{section.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ARCHITECTURE -->
  <section class="section-padding" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <div class="mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Internals
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          Architecture
        </h2>
        <p class="text-sm mt-3 max-w-2xl reveal reveal-delay-2" style="color: var(--color-text-secondary);">
          Every request passes through a middleware pipeline of autonomous layers before and after inference. Each layer can modify the request, gate execution, or enrich the response. The pipeline adds &lt;10ms total overhead to inference.
        </p>
      </div>

      <!-- Pipeline Flow -->
      <div class="card-gradient-border p-7 reveal reveal-delay-2">
        <div class="relative z-10">
          <h3 class="text-sm font-semibold tracking-wider uppercase mb-6" style="color: var(--color-text-tertiary);">Request Pipeline</h3>

          <div class="flex flex-col gap-0 items-center">
            {pipelineLayers.map((layer, i) => (
              <div class="w-full max-w-xl">
                <div
                  class="flex items-center gap-4 py-3 px-5 rounded-lg transition-all duration-200"
                  style={`background: ${i === pipelineLayers.length - 1 ? 'var(--color-accent-muted)' : 'var(--color-surface-elevated)'}; border: 1px solid ${i === pipelineLayers.length - 1 ? 'var(--color-accent)' : 'var(--color-border-subtle)'};`}
                >
                  <span class="font-mono text-[10px] font-bold tracking-wider w-6 text-center flex-shrink-0" style="color: var(--color-accent);">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span class={`text-sm font-semibold flex-shrink-0 w-28 ${i === pipelineLayers.length - 1 ? '' : ''}`} style={i === pipelineLayers.length - 1 ? 'color: var(--color-accent);' : ''}>
                    {layer.name}
                  </span>
                  <span class="text-xs flex-1" style="color: var(--color-text-tertiary);">{layer.description}</span>
                </div>
                {i < pipelineLayers.length - 1 && (
                  <div class="flex justify-center py-1">
                    <svg class="w-4 h-4" style="color: var(--color-border);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
                    </svg>
                  </div>
                )}
              </div>
            ))}
          </div>

          <div class="flex justify-center mt-4">
            <div class="flex items-center gap-2 px-4 py-2 rounded-lg" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border-subtle);">
              <svg class="w-4 h-4" style="color: var(--color-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
              </svg>
              <span class="text-xs font-medium" style="color: var(--color-text-tertiary);">Response passes back through all layers in reverse</span>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mt-12 reveal reveal-delay-3">
        <div class="text-center">
          <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">&lt;10ms</div>
          <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-2" style="color: var(--color-text-tertiary);">Pipeline overhead</div>
        </div>
        <div class="text-center md:border-l" style="border-color: var(--color-border-subtle);">
          <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">8</div>
          <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-2" style="color: var(--color-text-tertiary);">Middleware layers</div>
        </div>
        <div class="text-center md:border-l" style="border-color: var(--color-border-subtle);">
          <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">94.86%</div>
          <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-2" style="color: var(--color-text-tertiary);">Adversarial block</div>
        </div>
        <div class="text-center md:border-l" style="border-color: var(--color-border-subtle);">
          <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">0</div>
          <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-2" style="color: var(--color-text-tertiary);">External dependencies</div>
        </div>
      </div>
    </div>
  </section>

  <!-- AGENT DEVELOPMENT -->
  <section class="section-padding">
    <div class="container-max mx-auto">
      <div class="mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Extensibility
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          Creating Custom Agents
        </h2>
        <p class="text-sm mt-3 max-w-2xl reveal reveal-delay-2" style="color: var(--color-text-secondary);">
          Agents are created through the Agent Factory — describe what you need in plain English, and the 14-step pipeline handles design, testing, and deployment.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {agentConcepts.map((concept, i) => (
          <div
            class={`reveal reveal-delay-${Math.min(i + 1, 4)} rounded-xl p-6 transition-all duration-300 hover:scale-[1.02]`}
            style="background: var(--color-surface-elevated); border: 1px solid var(--color-border); border-top: 3px solid var(--color-accent);"
          >
            <div class="flex items-center gap-3 mb-3">
              <span class="font-mono text-sm font-bold" style="color: var(--color-accent);">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="text-sm font-semibold tracking-tight">{concept.label}</h3>
            </div>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-tertiary);">{concept.detail}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center reveal reveal-delay-4">
        <a href="/products" class="btn-outline text-xs uppercase">
          See production agents &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- SUPPORT -->
  <section class="section-padding" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <div class="mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Help
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          Support
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="reveal reveal-delay-1 card-gradient-border p-7">
          <div class="relative z-10">
            <span class="inline-block font-mono text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full mb-4" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2);">
              Beta
            </span>
            <h3 class="text-base font-semibold tracking-tight mb-3">Beta Customers</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              Direct line to engineering. Typical response within 4 hours during business hours. You're working with the team that builds the product.
            </p>
          </div>
        </div>

        <div class="reveal reveal-delay-2 card-gradient-border p-7">
          <div class="relative z-10">
            <span class="inline-block font-mono text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full mb-4" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.2);">
              License
            </span>
            <h3 class="text-base font-semibold tracking-tight mb-3">License Customers</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              Email support included with every RigRun license. Priority queue for licensed deployments. Configuration assistance and upgrade guidance.
            </p>
          </div>
        </div>

        <div class="reveal reveal-delay-3 card-gradient-border p-7">
          <div class="relative z-10">
            <span class="inline-block font-mono text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full mb-4" style="background: var(--color-accent-muted); color: var(--color-accent); border: 1px solid var(--color-accent);">
              Enterprise
            </span>
            <h3 class="text-base font-semibold tracking-tight mb-3">Enterprise</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              Dedicated technical support. On-premise installation assistance. Custom SLA available. Multi-node and classified environment expertise.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-12 text-center reveal reveal-delay-4">
        <a href="mailto:jesse@thornveil.ai" class="btn-primary">
          jesse@thornveil.ai
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  const lenis = new Lenis({ duration: 1.2, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
  function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);

  // Card tilt
  document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
    const MAX_DEG = 3;
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;
      card.style.transform = `perspective(800px) rotateX(${(0.5 - y) * MAX_DEG}deg) rotateY(${(x - 0.5) * MAX_DEG}deg)`;
      card.style.transition = 'transform 0.1s ease-out';
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg)';
      card.style.transition = 'transform 0.4s ease-out';
    });
  });
</script>
