---
import BaseLayout from '../layouts/BaseLayout.astro';

const papers = [
  { title: 'Selective-Buffer Streaming Safety for AI Coding Agents', category: 'cs.CR', pages: 8, file: 'paper1-safety' },
  { title: 'Zeroth-Order Preference Optimization on 100B+ Quantized MoE Models via Live Inference API', category: 'cs.LG', pages: 7, file: 'paper2-training' },
  { title: 'TurboQuant-SGLang: Compressed KV Cache Attention as a Plugin Backend', category: 'cs.DC', pages: 6, file: 'paper3-turboquant' },
  { title: 'Speculative Decoding Fails on Sparse MoE: A Negative Result and Practical Multi-Model Cascade Alternative', category: 'cs.SE', pages: 6, file: 'paper4-cascade' },
  { title: 'RigRun: Complete Local AI Infrastructure on a Single GPU', category: 'cs.AI', pages: 5, file: 'paper5-system' },
];

// Trade-secret-grade IP subsystems across the 10-system portfolio.
// No patent numbers, no application IDs — just named, defensible subsystems.
const ipSubsystems = [
  { system: 'Mycelium', subsystem: 'Substitute-on-failure MoE expert dispatch', evidence: 'Day-27 RTP with HMAC-chained audit log, 2026-05-08' },
  { system: 'Auspex', subsystem: 'Scope-as-code engagement compilation + 13-check Signet gate', evidence: 'Autonomous AD takeover validation with auditable replay package, 2026-05-16' },
  { system: 'RigRun', subsystem: 'Compile-time classification-gated routing with cross-domain guard', evidence: 'Type-system enforced; 44 NIST 800-53 controls implemented' },
  { system: 'RigRun', subsystem: '8-signal confidence pipeline with adversarial self-audit', evidence: '~4,220 LOC across 8 signals; cross-app parity in Go/Dart/TS' },
  { system: 'Signet', subsystem: 'HMAC-chained tamper-evident audit ledger with RFC 3161 anchoring', evidence: '2,400 LOC across chain.py + verifier.py + compactor.py; 7-state break taxonomy' },
  { system: 'HawkStack', subsystem: 'Compute-aware neural topology recipe (3-parameter)', evidence: '15 verified zoo checkpoints, R²=0.9895 power-law scaling fit on NUDT-SIRST' },
  { system: 'Pyros', subsystem: '24-layer adaptive control loop (PID + Holt + UCB1 + ε-greedy)', evidence: 'Race-clean CI across Linux/macOS/Windows; PAVA calibration validated vs sklearn' },
  { system: 'Meridian', subsystem: 'Phase 10 trade-secret primitives — attest, secdef, beacon, vehicle-id, log', evidence: '~5,500 LOC across 5 crates; not shipped in ArduPilot or PX4' },
  { system: 'Navigator', subsystem: '14-step Agent Factory with Opus calibration + 5-probe adversarial hardening', evidence: '9 production agents (OPORD, SBIR, security audit, etc.) generated by the pipeline' },
];
---

<BaseLayout
  title="Research | Thornveil"
  description="Five research papers documenting algorithms behind Thornveil's 10-system portfolio. Trade-secret-grade subsystems with cryptographic reduction-to-practice evidence."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-max mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Evidence</p>
      <h1 class="text-fluid-3xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">How Thornveil proves it works</h1>
      <p class="text-base mt-4 max-w-2xl leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        Every claim Thornveil makes is backed by working code, measured benchmarks, and where appropriate, cryptographically auditable reduction-to-practice. Five papers below. Public companion repositories on <a href="https://github.com/thornveil-ai" target="_blank" rel="noopener" style="color: var(--color-accent); text-decoration: underline;">github.com/thornveil-ai</a> for the rest.
      </p>
    </div>
  </section>

  <!-- PAPERS -->
  <section class="section-padding pt-12" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <h2 class="text-fluid-xl font-semibold tracking-tight mb-2 reveal">Research papers</h2>
      <p class="text-sm mb-8 max-w-2xl reveal reveal-delay-1" style="color: var(--color-text-secondary);">
        Peer-reviewable papers documenting the algorithms behind Thornveil's systems. HawkStack topology paper preparing arXiv submission; remaining four are technical reports.
      </p>
      <div class="space-y-3">
        {papers.map((p, i) => (
          <div class={`reveal reveal-delay-${Math.min(i + 1, 4)} rounded-xl p-5`} style="background: var(--color-surface-elevated); border: 1px solid var(--color-border);">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold tracking-tight">{p.title}</h3>
                <div class="flex items-center gap-3 mt-2">
                  <span class="font-mono text-[10px] tracking-wider uppercase px-2 py-0.5 rounded-full" style="background: var(--color-accent-muted); color: var(--color-accent);">{p.category}</span>
                  <span class="text-xs" style="color: var(--color-text-tertiary);">{p.pages} pages</span>
                  <span class="text-xs" style="color: var(--color-text-tertiary);">J. Morgan, 2026</span>
                </div>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <a href={`/papers/${p.file}.pdf`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-mono text-[10px] tracking-wider uppercase px-2 py-0.5 rounded-full transition-colors hover:opacity-80" style="background: var(--color-accent-muted); color: var(--color-accent);">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
                  PDF
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TRADE-SECRET-GRADE IP -->
  <section class="section-padding">
    <div class="container-max mx-auto">
      <h2 class="text-fluid-xl font-semibold tracking-tight reveal">Trade-secret-grade IP across the portfolio</h2>
      <p class="text-sm mt-3 mb-8 max-w-2xl reveal reveal-delay-1" style="color: var(--color-text-secondary);">
        Each Thornveil system carries one or more proprietary subsystems where the engineering work materially differentiates it from open-source alternatives. Listed below: the named subsystem, what makes it defensible, and the cryptographic or empirical evidence that backs the claim.
      </p>

      <div class="space-y-3 reveal reveal-delay-2">
        {ipSubsystems.map((s) => (
          <div class="rounded-xl p-5" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border);">
            <div class="flex items-start gap-4 flex-wrap">
              <span class="font-mono text-[10px] tracking-wider uppercase px-2 py-0.5 rounded-full shrink-0" style="background: var(--color-accent-muted); color: var(--color-accent);">{s.system}</span>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold tracking-tight">{s.subsystem}</h3>
                <p class="text-xs mt-1.5" style="color: var(--color-text-tertiary);">{s.evidence}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-3 gap-6 mt-12 reveal reveal-delay-3">
        {[
          { value: '10', label: 'Production systems' },
          { value: '9', label: 'Trade-secret subsystems documented' },
          { value: '5', label: 'Research papers' },
        ].map((m) => (
          <div class="text-center">
            <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">{m.value}</div>
            <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-2" style="color: var(--color-text-tertiary);">{m.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  const lenis = new Lenis({ duration: 1.2, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
  function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);
</script>
