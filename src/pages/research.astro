---
import BaseLayout from '../layouts/BaseLayout.astro';

const papers = [
  { title: 'Selective-Buffer Streaming Safety for AI Coding Agents', category: 'cs.CR', pages: 8, file: 'paper1-safety' },
  { title: 'Zeroth-Order Preference Optimization on 100B+ Quantized MoE Models via Live Inference API', category: 'cs.LG', pages: 7, file: 'paper2-training' },
  { title: 'TurboQuant-SGLang: Compressed KV Cache Attention as a Plugin Backend', category: 'cs.DC', pages: 6, file: 'paper3-turboquant' },
  { title: 'Speculative Decoding Fails on Sparse MoE: A Negative Result and Practical Multi-Model Cascade Alternative', category: 'cs.SE', pages: 6, file: 'paper4-cascade' },
  { title: 'RigRun: Complete Local AI Infrastructure on a Single GPU', category: 'cs.AI', pages: 5, file: 'paper5-system' },
];

const patents = [
  { num: '001', app: '64/004,046', date: 'Mar 12, 2026', title: 'Acoustic Direction-of-Arrival Estimation Using RPM-Indexed Self-Noise Cancellation on an Airborne Interceptor UAV', domain: 'Counter-UAS' },
  { num: '002', app: '64/004,056', date: 'Mar 12, 2026', title: 'Classification-Gated Routing System for Language Model Inference with Downgrade Prevention', domain: 'AI Safety' },
  { num: '003', app: '64/004,109', date: 'Mar 12, 2026', title: 'Learned Differentiable CLAHE Module for End-to-End Neural Network Image Enhancement', domain: 'Computer Vision' },
  { num: '004', app: '64/004,170', date: 'Mar 12, 2026', title: 'Anti-Bypass Spillage Detection for Secure AI Inference Pipelines', domain: 'AI Safety' },
  { num: '005', app: '64/004,181', date: 'Mar 12, 2026', title: 'Hybrid Native-Synthetic Reasoning with Classification-Gated Thinking Depth Control', domain: 'AI Infrastructure' },
  { num: '006', app: '64/004,206', date: 'Mar 12, 2026', title: 'Multi-Agent Deep RL for Autonomous Counter-UAS Intercept Guidance', domain: 'Counter-UAS' },
  { num: '007', app: '64/004,226', date: 'Mar 13, 2026', title: 'IFF Re-verification at Instant of Discharge with Pursue-Without-Engagement Fallback', domain: 'Counter-UAS' },
  { num: '008', app: '64/006,415', date: 'Mar 15, 2026', title: 'Multi-Condition Continuous Engagement Authorization Revocation for Autonomous Interceptors', domain: 'Counter-UAS' },
  { num: '009', app: '64/006,416', date: 'Mar 15, 2026', title: 'Heterogeneous ISA Platform for Safety-Critical Engagement Authorization', domain: 'Counter-UAS' },
  { num: '010', app: '64/006,408', date: 'Mar 15, 2026', title: 'Multi-Signal Adaptive Confidence Scoring with Confabulation Detection', domain: 'AI Safety' },
  { num: '011', app: '64/006,412', date: 'Mar 15, 2026', title: 'Deep RL for Fixed-Wing UAV Forward-Firing Gun Engagement of sUAS Targets', domain: 'Counter-UAS' },
  { num: '012', app: '64/006,433', date: 'Mar 15, 2026', title: 'Hierarchical Triple-Key Error-Report Disambiguation in Arabic Diacritization', domain: 'Arabic NLP' },
  { num: '013', app: '64/006,451', date: 'Mar 15, 2026', title: 'Contrastive Dual-Head Neural Corrector for Arabic Diacritization', domain: 'Arabic NLP' },
  { num: '014', app: '64/006,440', date: 'Mar 15, 2026', title: 'Communication-Optimized Blade Geometry for Acoustic Data Transmission', domain: 'Counter-UAS' },
  { num: '015', app: '64/006,438', date: 'Mar 15, 2026', title: 'Spatial Grid-Accelerated Contamination Zone Fusion for CBRN Sensor Networks', domain: 'CBRN' },
  { num: '016', app: '64/006,430', date: 'Mar 15, 2026', title: 'ISA 2.0 Canonical Data Model with CAIRN-Extended CoT for CBRN Networks', domain: 'CBRN' },
  { num: '017', app: '64/006,442', date: 'Mar 15, 2026', title: 'Tactical Mobile C2 for Armed Counter-UAS Interceptors via MAVLink', domain: 'Counter-UAS' },
  { num: '018', app: '64/017,293', date: 'Mar 25, 2026', title: 'Selective-Buffer Streaming Safety Proxy for LLM Tool Calls', domain: 'AI Safety' },
  { num: '019', app: '64/017,303', date: 'Mar 26, 2026', title: 'Closed-Loop Self-Improvement for Local Language Models', domain: 'AI Training' },
  { num: '020', app: '64/017,322', date: 'Mar 26, 2026', title: 'Multi-Stage Cascade Routing with Entropy-Based Escalation', domain: 'AI Infrastructure' },
  { num: '021', app: '64/017,334', date: 'Mar 26, 2026', title: 'Classification-Isolated Memory with Hardware-Backed Encryption', domain: 'AI Safety' },
  { num: '022', app: '64/017,344', date: 'Mar 26, 2026', title: 'Distributed Adaptive AI Mesh with Predictive Expert Prefetching and PoI', domain: 'Mesh/P2P' },
  { num: '023', app: '64/020,331', date: 'Mar 28, 2026', title: 'Zero-Downtime Self-Improvement via Zeroth-Order Optimization', domain: 'AI Training' },
  { num: '024', app: '64/020,345', date: 'Mar 28, 2026', title: 'Cross-Domain Small Object Detection with Reparameterizable Sub-2M Backbone', domain: 'Computer Vision' },
  { num: '025', app: '64/020,358', date: 'Mar 28, 2026', title: 'Autonomous Agent Manufacturing via Meta-Agent Pipeline', domain: 'AI Infrastructure' },
  { num: '026', app: '64/020,371', date: 'Mar 28, 2026', title: 'Predictive Loss Surface Topology Analysis with Fresh-Optimizer Cyclic Training', domain: 'Computer Vision' },
  { num: '027', app: '64/020,384', date: 'Mar 28, 2026', title: 'Adaptive Inference Parameter Regulation via Multi-Signal PID Control', domain: 'AI Infrastructure' },
];

const domainColors: Record<string, string> = {
  'Counter-UAS': 'var(--color-accent)',
  'AI Safety': '#ef4444',
  'AI Infrastructure': '#8b5cf6',
  'AI Training': '#06b6d4',
  'Computer Vision': '#f59e0b',
  'Arabic NLP': '#10b981',
  'CBRN': '#f97316',
  'Mesh/P2P': '#3b82f6',
};
---

<BaseLayout
  title="Evidence | Thornveil"
  description="Every claim we make about RigRun, Pyros, and Mycelium is backed by working code, measured benchmarks, and published research. Here's the evidence."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-max mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Evidence</p>
      <h1 class="text-fluid-3xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">How we prove it works</h1>
      <p class="text-base mt-4 max-w-2xl leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        Every claim we make about RigRun, Pyros, and Mycelium is backed by working code, measured benchmarks, and published research. Here's the evidence.
      </p>
    </div>
  </section>

  <!-- PAPERS -->
  <section class="section-padding pt-12" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <h2 class="text-fluid-xl font-semibold tracking-tight mb-2 reveal">Published research</h2>
      <p class="text-sm mb-8 max-w-2xl reveal reveal-delay-1" style="color: var(--color-text-secondary);">
        Peer-reviewable papers documenting the algorithms that make the product work. If a vendor can't show the math, you're buying marketing.
      </p>
      <div class="space-y-3">
        {papers.map((p, i) => (
          <div class={`reveal reveal-delay-${Math.min(i + 1, 4)} rounded-xl p-5`} style="background: var(--color-surface-elevated); border: 1px solid var(--color-border);">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold tracking-tight">{p.title}</h3>
                <div class="flex items-center gap-3 mt-2">
                  <span class="font-mono text-[10px] tracking-wider uppercase px-2 py-0.5 rounded-full" style="background: var(--color-accent-muted); color: var(--color-accent);">{p.category}</span>
                  <span class="text-xs" style="color: var(--color-text-tertiary);">{p.pages} pages</span>
                  <span class="text-xs" style="color: var(--color-text-tertiary);">J. Morgan, 2026</span>
                </div>
              </div>
              <span class="font-mono text-[10px] tracking-wider uppercase px-2 py-0.5 rounded-full shrink-0" style="background: var(--color-accent-muted); color: var(--color-accent);">
                Submitted April 2026
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PATENTS -->
  <section class="section-padding">
    <div class="container-max mx-auto">
      <div class="flex items-end justify-between mb-8 flex-wrap gap-4">
        <div>
          <h2 class="text-fluid-xl font-semibold tracking-tight reveal">Protected IP you license, not rebuild</h2>
          <p class="text-sm mt-2 max-w-2xl reveal reveal-delay-1" style="color: var(--color-text-secondary);">
            When you buy Thornveil, you get the benefit of filed, defensible methods — not a wrapper around someone else's API. Full U.S. provisional applications, assigned to Thornveil LLC, available for license.
          </p>
        </div>
        <div class="flex flex-wrap gap-2 reveal reveal-delay-2">
          {Object.entries(domainColors).map(([domain, color]) => (
            <span class="flex items-center gap-1.5 text-[10px]" style="color: var(--color-text-tertiary);">
              <span class="w-2 h-2 rounded-full" style={`background: ${color};`}></span>
              {domain}
            </span>
          ))}
        </div>
      </div>

      <div class="rounded-xl overflow-hidden reveal reveal-delay-2" style="border: 1px solid var(--color-border);">
        {patents.map((p, i) => (
          <div
            class="flex items-center gap-4 px-5 py-3 text-xs transition-colors hover:bg-[var(--color-accent-muted)]"
            style={`border-bottom: 1px solid var(--color-border-subtle); ${i === patents.length - 1 ? 'border-bottom: none;' : ''}`}
          >
            <span class="font-mono font-bold w-8 shrink-0" style="color: var(--color-accent);">{p.num}</span>
            <span class="w-2 h-2 rounded-full shrink-0" style={`background: ${domainColors[p.domain] || 'var(--color-text-tertiary)'};`}></span>
            <span class="flex-1 min-w-0 truncate">{p.title}</span>
            <span class="font-mono shrink-0 hidden sm:block" style="color: var(--color-text-tertiary);">{p.app}</span>
            <span class="shrink-0 hidden md:block" style="color: var(--color-text-tertiary);">{p.date}</span>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-3 gap-6 mt-12 reveal reveal-delay-3">
        {[
          { value: '27', label: 'Filed methods you can license' },
          { value: '8', label: 'Problem areas we solve' },
          { value: '5', label: 'Papers with reproducible math' },
        ].map((m) => (
          <div class="text-center">
            <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">{m.value}</div>
            <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-2" style="color: var(--color-text-tertiary);">{m.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  const lenis = new Lenis({ duration: 1.2, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
  function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);
</script>
