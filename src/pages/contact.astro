---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Contact | Thornveil"
  description="Get in touch with Thornveil for teaming opportunities, SBIR partnerships, or defense technology consulting."
>
  <PageHero
    title="Get in Touch"
    subtitle="Whether you're a program manager, a prime looking for a teaming partner, or a fellow builder — reach out."
  />

  <section class="section-padding relative">
    <div class="container-max mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-3">
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-6 reveal"
          >
            <!-- Honeypot -->
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-xs font-semibold tracking-wider uppercase text-white/40 mb-2">
                  Name <span class="text-teal">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full bg-white/[0.03] border border-white/10 rounded px-4 py-3 text-white placeholder-white/20 focus:border-teal/50 focus:outline-none focus:ring-1 focus:ring-teal/30 transition-colors"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="organization" class="block text-xs font-semibold tracking-wider uppercase text-white/40 mb-2">
                  Organization
                </label>
                <input
                  type="text"
                  id="organization"
                  name="organization"
                  class="w-full bg-white/[0.03] border border-white/10 rounded px-4 py-3 text-white placeholder-white/20 focus:border-teal/50 focus:outline-none focus:ring-1 focus:ring-teal/30 transition-colors"
                  placeholder="Company or agency"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-xs font-semibold tracking-wider uppercase text-white/40 mb-2">
                Email <span class="text-teal">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-white/[0.03] border border-white/10 rounded px-4 py-3 text-white placeholder-white/20 focus:border-teal/50 focus:outline-none focus:ring-1 focus:ring-teal/30 transition-colors"
                placeholder="you@example.com"
              />
            </div>

            <div>
              <label for="subject" class="block text-xs font-semibold tracking-wider uppercase text-white/40 mb-2">
                Subject
              </label>
              <select
                id="subject"
                name="subject"
                class="w-full bg-white/[0.03] border border-white/10 rounded px-4 py-3 text-white focus:border-teal/50 focus:outline-none focus:ring-1 focus:ring-teal/30 transition-colors"
              >
                <option value="general" class="bg-navy">General Inquiry</option>
                <option value="teaming" class="bg-navy">Teaming Opportunity</option>
                <option value="sbir" class="bg-navy">SBIR Partnership</option>
                <option value="other" class="bg-navy">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-xs font-semibold tracking-wider uppercase text-white/40 mb-2">
                Message <span class="text-teal">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                class="w-full bg-white/[0.03] border border-white/10 rounded px-4 py-3 text-white placeholder-white/20 focus:border-teal/50 focus:outline-none focus:ring-1 focus:ring-teal/30 transition-colors resize-none"
                placeholder="Tell us about your project or opportunity..."
              ></textarea>
            </div>

            <button type="submit" class="btn-primary">
              Send Message
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
            </button>
          </form>
        </div>

        <!-- Contact info sidebar -->
        <div class="lg:col-span-2 reveal reveal-delay-2">
          <div class="bg-white/[0.02] border border-white/5 rounded-lg p-8 space-y-8">
            <div>
              <h3 class="text-xs font-semibold tracking-[0.3em] uppercase text-teal mb-4">Email</h3>
              <a href="mailto:contact@thornveil.ai" class="text-white/70 hover:text-white transition-colors">
                contact@thornveil.ai
              </a>
            </div>

            <div>
              <h3 class="text-xs font-semibold tracking-[0.3em] uppercase text-teal mb-4">Location</h3>
              <p class="text-white/40">Virginia, USA</p>
            </div>

            <div>
              <h3 class="text-xs font-semibold tracking-[0.3em] uppercase text-teal mb-4">Response Time</h3>
              <p class="text-white/40 text-sm leading-relaxed">
                Typically within 24 hours. For urgent SBIR or teaming inquiries, note it in the subject line.
              </p>
            </div>

            <div class="pt-4 border-t border-white/5">
              <h3 class="text-xs font-semibold tracking-[0.3em] uppercase text-teal mb-4">Business Details</h3>
              <div class="space-y-2 text-sm text-white/30">
                <p>Thornveil LLC</p>
                <p>NAICS 541511, 541512</p>
                <p>Virginia LLC</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
