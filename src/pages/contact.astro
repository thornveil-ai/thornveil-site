---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Thornveil"
  description="Contract engineering, technical advisory, IP licensing, agent products. Reach Jesse Morgan at Thornveil LLC."
>
  <section class="section-padding pt-32 md:pt-40 relative overflow-hidden">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full pointer-events-none" style="opacity: 0.05; background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"></div>

    <div class="relative container-max mx-auto max-w-2xl text-center">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Contact</p>
      <h1 class="text-fluid-3xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">Let's build something</h1>
      <p class="text-base mt-4 max-w-lg mx-auto leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        Contract engineering, technical advisory, IP licensing, custom AI agents, or hard problems that need solving fast.
      </p>

      <div class="mt-10 reveal reveal-delay-2">
        <a href="mailto:jesse@thornveil.ai" class="btn-primary text-base">
          jesse@thornveil.ai
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </a>
      </div>

      <div class="divider my-16 reveal reveal-delay-3"></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 text-left reveal reveal-delay-3">
        <div class="rounded-xl p-6" style="background: var(--color-surface-secondary); border: 1px solid var(--color-border);">
          <h3 class="text-sm font-semibold mb-4">What I do</h3>
          <ul class="space-y-2 text-sm" style="color: var(--color-text-secondary);">
            <li>Contract AI/ML engineering</li>
            <li>Defense technology development</li>
            <li>SBIR/STTR proposal writing</li>
            <li>Technical advisory</li>
            <li>IP licensing</li>
            <li>Custom AI agent development</li>
          </ul>
        </div>

        <div class="rounded-xl p-6" style="background: var(--color-surface-secondary); border: 1px solid var(--color-border);">
          <h3 class="text-sm font-semibold mb-4">Company details</h3>
          <div class="space-y-2 text-sm" style="color: var(--color-text-secondary);">
            <div><span class="font-mono text-xs" style="color: var(--color-text-tertiary);">Entity</span><br/>Thornveil LLC</div>
            <div><span class="font-mono text-xs" style="color: var(--color-text-tertiary);">Location</span><br/>Tampa, FL</div>
            <div><span class="font-mono text-xs" style="color: var(--color-text-tertiary);">NAICS</span><br/>541511, 541512</div>
            <div><span class="font-mono text-xs" style="color: var(--color-text-tertiary);">IP</span><br/>23 provisional patents filed</div>
          </div>
        </div>
      </div>

      <div class="mt-12 font-mono flex flex-wrap justify-center gap-x-3 gap-y-1 text-[10px] tracking-[0.15em] uppercase reveal reveal-delay-4" style="color: var(--color-text-tertiary);">
        <span>831-275-8979</span>
        <span class="opacity-40">&middot;</span>
        <span>jesse@thornveil.ai</span>
        <span class="opacity-40">&middot;</span>
        <span>Tampa, FL</span>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  const lenis = new Lenis({ duration: 1.2, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
  function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);
</script>
