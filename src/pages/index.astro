---
import BaseLayout from '../layouts/BaseLayout.astro';

const domains = [
  {
    title: 'Counter-UAS & Threat Detection',
    description: 'Thermal and visual drone detection with state-of-the-art deep learning. Autonomous intercept planning. TAK-native integration.',
    tags: ['Computer Vision', 'Edge Inference', 'TAK'],
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    title: 'Swarm Communications',
    description: 'Acoustic intra-swarm comms and cooperative positioning — no GPS, no RF. Propeller-modulated data encoding with sub-decimeter accuracy.',
    tags: ['GPS-Denied', 'Acoustic', 'EKF'],
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" /></svg>',
  },
  {
    title: 'CBRN Sensor Fusion',
    description: 'Real-time chemical sensor dashboards fusing JCAD, AP4C, ACADA, and LCD data. Automated threat classification with TAK publishing.',
    tags: ['Sensor Fusion', 'Chemical Defense', 'MIL-STD-2525'],
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>',
  },
  {
    title: 'AI Decision Support',
    description: 'Role-aware AI assistants for military staff. Classification-compliant LLM routing. FIPS 140-3 crypto, CAC/PKI auth, IL5-ready.',
    tags: ['LLM', 'FIPS 140-3', 'Zero Trust'],
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>',
  },
];

const work = [
  {
    label: 'AI Digital Staff Officer',
    detail: '8,400 lines Go + 4,400 lines TypeScript. FIPS 140-3, CAC/PKI, 4 database backends. Built for a Marine Corps training command.',
  },
  {
    label: 'Thermal Drone Detection',
    detail: 'FCOS + ConvNeXt-Tiny detector on thermal UAV data. 27 architecture iterations. Trained on NVIDIA GH200.',
  },
  {
    label: 'Acoustic Swarm Comms',
    detail: 'GPS-denied cooperative positioning via acoustic ranging. 12 feasibility experiments, 177 tests passing. TRL 3.',
  },
  {
    label: 'Arabic NLP Systems',
    detail: 'Grammatical error correction within 6x fewer parameters than SOTA. Diacritization engine 62x smaller at ~2.5% DER.',
  },
  {
    label: 'S&T Decision Platform',
    detail: 'Technology radar, capital flow tracking, MCDA scoring. 21 NIST 800-53 controls. SBIR proposal delivered to SpaceWERX.',
  },
];
---

<BaseLayout>
  <!-- ============================================ -->
  <!-- HERO — White bg, logo animation video        -->
  <!-- ============================================ -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-white">
    <!-- Subtle grid -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(19,42,76,.08) 1px, transparent 1px), linear-gradient(90deg, rgba(19,42,76,.08) 1px, transparent 1px); background-size: 80px 80px;"></div>

    <div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
      <!-- Logo: video animation → static mark -->
      <div class="mx-auto mb-10 w-72 h-48 md:w-[28rem] md:h-72 relative">
        <video
          id="hero-video"
          autoplay
          muted
          playsinline
          class="absolute inset-0 w-full h-full object-contain transition-opacity duration-1000"
        >
          <source src="/hero-video.mp4" type="video/mp4" />
        </video>
        <img
          src="/logo-stacked.png"
          alt="Thornveil"
          class="absolute inset-0 w-full h-full object-contain opacity-0 transition-opacity duration-1000"
          id="hero-logo-static"
        />
      </div>

      <p class="text-base md:text-lg text-navy/50 max-w-lg mx-auto leading-relaxed">
        Defense AI and autonomous systems. One engineer, end to end.
      </p>

      <div class="mt-10">
        <a href="#work" class="inline-flex items-center gap-2 border border-navy/20 hover:border-navy/40 hover:bg-navy/5 text-navy font-semibold px-8 py-3.5 rounded transition-all duration-300 tracking-wide text-xs uppercase">
          See the work
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
      <div class="w-px h-10 bg-gradient-to-b from-navy/20 to-transparent animate-pulse"></div>
    </div>
  </section>

  <!-- White → dark transition -->
  <div class="h-48 bg-gradient-to-b from-white to-navy-dark"></div>

  <!-- ============================================ -->
  <!-- CAPABILITIES — What I build                  -->
  <!-- ============================================ -->
  <section id="work" class="section-padding relative">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-dark to-navy"></div>

    <div class="relative container-max mx-auto">
      <div class="mb-14">
        <p class="text-xs font-semibold tracking-[0.3em] uppercase text-teal mb-3 reveal">Focus Areas</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight reveal reveal-delay-1">
          What I build
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {domains.map((d, i) => (
          <div class={`reveal reveal-delay-${i + 1} group card-glow rounded-lg bg-white/[0.02] border border-white/5 p-7 hover:bg-white/[0.04] transition-all duration-500`}>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-teal/10 border border-teal/20 flex items-center justify-center flex-shrink-0 text-teal-light group-hover:bg-teal/20 transition-colors">
                <Fragment set:html={d.icon} />
              </div>
              <div>
                <h3 class="text-base font-semibold tracking-tight mb-2">{d.title}</h3>
                <p class="text-white/40 text-sm leading-relaxed">{d.description}</p>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {d.tags.map((t) => (
                    <span class="text-[10px] font-medium tracking-wider uppercase text-teal-light/60 bg-teal/8 px-2 py-0.5 rounded border border-teal/10">{t}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- WORK — The receipts                          -->
  <!-- ============================================ -->
  <section id="background" class="section-padding relative">
    <div class="absolute inset-0 bg-navy-dark/60"></div>

    <div class="relative container-max mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Left: context -->
        <div class="lg:col-span-2">
          <p class="text-xs font-semibold tracking-[0.3em] uppercase text-teal mb-3 reveal">Background</p>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-6 reveal reveal-delay-1">
            One person, full stack
          </h2>
          <div class="space-y-4 text-white/40 text-sm leading-relaxed reveal reveal-delay-2">
            <p>
              Marine. Arabic linguist. Software engineer. ML researcher. I build defense technology from PyTorch training runs to Go backends to React tactical dashboards to LaTeX proposals.
            </p>
            <p>
              No team. No overhead. No six-month procurement cycles for a database decision. Concept to working code in days.
            </p>
          </div>

          <div class="mt-8 pt-6 border-t border-white/5 reveal reveal-delay-3">
            <div class="grid grid-cols-2 gap-6">
              <div>
                <div class="text-2xl font-bold text-white">3</div>
                <div class="text-xs text-white/30 mt-1">SBIR proposals<br/>delivered</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-white">IL5</div>
                <div class="text-xs text-white/30 mt-1">compliance<br/>architecture</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: track record -->
        <div class="lg:col-span-3 reveal reveal-delay-2">
          <div class="bg-white/[0.02] border border-white/5 rounded-lg divide-y divide-white/5">
            {work.map((w) => (
              <div class="px-7 py-5 hover:bg-white/[0.02] transition-colors">
                <div class="text-sm font-semibold text-white/80 mb-1">{w.label}</div>
                <div class="text-xs text-white/35 leading-relaxed">{w.detail}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- CONTACT — Simple                             -->
  <!-- ============================================ -->
  <section id="contact" class="section-padding relative">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-dark/60 to-navy"></div>

    <div class="relative container-max mx-auto max-w-2xl text-center">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight reveal">
        Get in touch
      </h2>
      <p class="mt-4 text-white/40 text-sm max-w-md mx-auto leading-relaxed reveal reveal-delay-1">
        Teaming opportunities, SBIR partnerships, or hard problems that need solving fast.
      </p>

      <div class="mt-8 reveal reveal-delay-2">
        <a href="mailto:jesse@thornveil.ai" class="btn-primary">
          jesse@thornveil.ai
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </a>
      </div>

      <div class="mt-12 flex flex-wrap justify-center gap-6 text-xs text-white/20 reveal reveal-delay-3">
        <span>Thornveil LLC</span>
        <span class="text-white/10">|</span>
        <span>Tampa, FL</span>
        <span class="text-white/10">|</span>
        <span>NAICS 541511, 541512</span>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Cross-fade video → static logo when animation ends
  const video = document.getElementById('hero-video') as HTMLVideoElement;
  const staticLogo = document.getElementById('hero-logo-static') as HTMLImageElement;

  if (video && staticLogo) {
    video.addEventListener('ended', () => {
      video.style.opacity = '0';
      staticLogo.style.opacity = '1';
    });

    video.addEventListener('error', () => {
      video.style.opacity = '0';
      staticLogo.style.opacity = '1';
    });
  }
</script>
