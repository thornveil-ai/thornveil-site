---
import BaseLayout from '../layouts/BaseLayout.astro';
import CapabilityCard from '../components/CapabilityCard.astro';

const capabilities = [
  {
    title: 'Counter-UAS',
    description: 'Thermal detection, autonomous intercept, and threat neutralization systems for the counter-drone fight.',
    icon: '<svg class="w-6 h-6 text-teal-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    title: 'Swarm Intelligence',
    description: 'GPS-denied communications and cooperative positioning for autonomous multi-agent operations.',
    icon: '<svg class="w-6 h-6 text-teal-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 003.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0120.25 6v1.5m0 9V18A2.25 2.25 0 0118 20.25h-1.5m-9 0H6A2.25 2.25 0 013.75 18v-1.5M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    title: 'CBRN Sensing',
    description: 'Multi-sensor fusion dashboards and tactical common operating pictures for chemical defense.',
    icon: '<svg class="w-6 h-6 text-teal-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>',
  },
  {
    title: 'AI Decision Support',
    description: 'Mission-aware AI assistants and classification-compliant LLM systems for the warfighter.',
    icon: '<svg class="w-6 h-6 text-teal-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>',
  },
];

const stats = [
  { value: 3, label: 'SBIR Awards', suffix: '' },
  { value: 6, label: 'Active Programs', suffix: '' },
  { value: 1, label: 'Engineer', suffix: '' },
  { value: 5, label: 'IL Compliance', prefix: 'IL' },
];
---

<BaseLayout>
  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background layers -->
    <div class="absolute inset-0 bg-navy-dark"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(74,110,125,0.06)_0%,_transparent_70%)]"></div>

    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <!-- Video background -->
    <div class="absolute inset-0 flex items-center justify-center opacity-10">
      <video
        autoplay
        muted
        playsinline
        class="w-full max-w-2xl"
        poster="/logo-stacked.png"
      >
        <source src="/hero-video.mp4" type="video/mp4" />
      </video>
    </div>

    <!-- Content -->
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <!-- Logo mark -->
      <div class="mb-10 flex justify-center">
        <img src="/favicon.png" alt="" class="w-20 h-20 md:w-24 md:h-24 opacity-90" />
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight font-poppins">
        <span class="text-white">THORN</span><span class="text-teal-light">VEIL</span>
      </h1>

      <p class="mt-4 text-lg md:text-2xl font-light tracking-[0.2em] uppercase text-white/40">
        Built at the Edge
      </p>

      <p class="mt-8 text-base md:text-lg text-white/50 max-w-xl mx-auto leading-relaxed">
        Defense AI and autonomous systems. From concept to prototype to SBIR win.
      </p>

      <div class="mt-12">
        <a href="/capabilities" class="btn-primary">
          Explore Capabilities
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30">
        <span class="text-[10px] tracking-widest uppercase">Scroll</span>
        <div class="w-px h-8 bg-gradient-to-b from-white/50 to-transparent animate-pulse"></div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- CAPABILITIES OVERVIEW                        -->
  <!-- ============================================ -->
  <section class="section-padding relative">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-dark via-navy to-navy"></div>

    <div class="relative container-max mx-auto">
      <div class="mb-16">
        <p class="text-xs font-semibold tracking-[0.3em] uppercase text-teal mb-4 reveal">What We Build</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight reveal reveal-delay-1">
          End-to-end defense technology
        </h2>
        <div class="mt-4 w-12 h-0.5 bg-teal reveal reveal-delay-2"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {capabilities.map((cap, i) => (
          <CapabilityCard
            title={cap.title}
            description={cap.description}
            icon={cap.icon}
            delay={i + 1}
          />
        ))}
      </div>

      <div class="mt-12 text-center reveal">
        <a href="/capabilities" class="btn-outline">
          View All Capabilities
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- STATS — THE FLEX                             -->
  <!-- ============================================ -->
  <section class="section-padding relative overflow-hidden">
    <!-- Dark background with subtle accent -->
    <div class="absolute inset-0 bg-navy-dark"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_rgba(74,110,125,0.08)_0%,_transparent_60%)]"></div>

    <div class="relative container-max mx-auto">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
        {stats.map((stat, i) => (
          <div class={`reveal reveal-delay-${i + 1} text-center md:text-left`}>
            <div class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-white stat-number" data-target={stat.value} data-prefix={stat.prefix || ''}>
              {stat.prefix || ''}{stat.value}
            </div>
            <div class="mt-2 text-sm md:text-base text-white/40 font-medium tracking-wide">
              {stat.label}
            </div>
            {stat.label === 'Engineer' && (
              <div class="mt-1 text-xs text-teal/60 tracking-wider">
                Yes, one.
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- CTA                                          -->
  <!-- ============================================ -->
  <section class="section-padding relative">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-dark to-navy"></div>

    <div class="relative container-max mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight reveal">
        Ready to talk?
      </h2>
      <p class="mt-4 text-white/40 text-lg max-w-lg mx-auto reveal reveal-delay-1">
        Whether it's a teaming opportunity, an SBIR partnership, or a hard problem that needs solving.
      </p>
      <div class="mt-10 reveal reveal-delay-2">
        <a href="/contact" class="btn-primary">
          Get in Touch
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Animated stat counters
  const counters = document.querySelectorAll('.stat-number');
  const counterObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target || '0');
          const prefix = el.dataset.prefix || '';
          let current = 0;
          const duration = 1500;
          const step = Math.max(1, Math.floor(target / (duration / 30)));
          const interval = setInterval(() => {
            current = Math.min(current + step, target);
            el.textContent = prefix + current.toString();
            if (current >= target) clearInterval(interval);
          }, 30);
          counterObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.3 }
  );
  counters.forEach((c) => counterObserver.observe(c));
</script>
