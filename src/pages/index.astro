          class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal"
          style="color: var(--color-accent);"
        >
          Product Lines
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          What we build
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {products.map((p, i) => {
          const Tag = p.href ? 'a' : 'div';
          const linkProps = p.href ? { href: p.href, target: '_blank', rel: 'noopener noreferrer' } : {};
