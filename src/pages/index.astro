---
import BaseLayout from '../layouts/BaseLayout.astro';

const pillars = [
  {
    name: 'RigRun',
    subtitle: 'Single-Node Sovereign AI',
    description: 'Complete AI infrastructure on one GPU. 122B model at 105 tok/s, autonomous agent factory, self-improving training pipeline, 5-layer safety stack. Zero cloud dependency.',
    metric: '105',
    metricLabel: 'tok/s',
    href: '/technology',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
  },
  {
    name: 'Mycelium',
    subtitle: 'P2P AI Mesh Network',
    description: 'Connect any device into a self-healing mesh. Distributed MoE over consumer WiFi, proof-of-inference trust verification, graceful degradation. Never "service unavailable."',
    metric: '0.5',
    metricLabel: 'ms p50',
    href: '/technology',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>`,
  },
  {
    name: 'Agent Factory',
    subtitle: 'AI That Builds AI Agents',
    description: 'Describe what you need in plain English. The factory designs, tests, and deploys a production-ready domain expert agent with tools, knowledge base, and quality assurance.',
    metric: '6',
    metricLabel: 'agents live',
    href: '/products',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-5.1m0 0L11.42 4.97m-5.1 5.1H20.4m-4.98 0l5.1 5.1m0 0l-5.1 5.1m5.1-5.1H3.6" /></svg>`,
  },
];

const metrics = [
  { value: '27', label: 'Patents Filed' },
  { value: '5', label: 'ArXiv Papers' },
  { value: '6', label: 'Production Agents' },
  { value: '122B', label: 'Parameters' },
];

const agents = [
  { name: 'Code Reviewer', subtitle: 'Senior Principal Security Engineer', domain: 'Security + Bugs', tools: 9, accent: '#ef4444' },
  { name: 'Security Auditor', subtitle: 'Principal AppSec Engineer', domain: 'CWE/OWASP/CVSS', tools: 11, accent: '#f97316' },
  { name: 'Doc Writer', subtitle: 'Senior Documentation Architect', domain: 'Technical Docs', tools: 10, accent: '#3b82f6' },
  { name: 'Sprint Planner', subtitle: 'Senior Engineering Manager', domain: 'Agile Planning', tools: 10, accent: '#8b5cf6' },
  { name: 'SBIR Writer', subtitle: 'Federal Grant Strategist', domain: 'DoD Proposals', tools: 7, accent: '#C9A84E' },
  { name: 'Patent Drafter', subtitle: 'Software Patent Attorney', domain: 'IP/Legal', tools: 10, accent: '#10b981' },
];
---

<BaseLayout
  title="Thornveil | Sovereign AI Infrastructure"
  description="Sovereign AI infrastructure from edge to enterprise. 27 patents filed. Agent factory, P2P mesh, local model inference. Built by Jesse Morgan."
>
  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden gradient-mesh">
    <div
      class="absolute inset-0"
      style="opacity: 0.025; background-image: linear-gradient(var(--color-text-primary) 1px, transparent 1px), linear-gradient(90deg, var(--color-text-primary) 1px, transparent 1px); background-size: 80px 80px;"
    ></div>

    <div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
      <div class="mx-auto mb-10 w-72 h-48 md:w-[28rem] md:h-64 relative animate-fade-in">
        <img src="/logo-stacked-white.png" alt="Thornveil" class="logo-dark absolute inset-0 w-full h-full object-contain" style="transition: opacity 0.5s;" />
        <img src="/logo-stacked.png" alt="Thornveil" class="logo-light absolute inset-0 w-full h-full object-contain" style="opacity: 0; transition: opacity 0.5s;" />
      </div>

      <h2 class="text-fluid-2xl max-w-xl mx-auto leading-tight font-semibold tracking-tight">
        Sovereign AI infrastructure.<br/>From edge to enterprise.
      </h2>

      <div class="mt-6 font-mono text-[10px] md:text-xs tracking-[0.2em] uppercase" style="color: var(--color-text-tertiary);">
        <span>27 Patents Filed</span>
        <span class="mx-2 md:mx-3 opacity-40">///</span>
        <span>5 ArXiv Papers</span>
        <span class="mx-2 md:mx-3 opacity-40">///</span>
        <span>Tampa, FL</span>
      </div>

      <div class="mt-10 flex gap-4 justify-center flex-wrap">
        <a href="/products" class="btn-primary text-xs uppercase">
          View Products
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="/technology" class="btn-outline text-xs uppercase">
          See the Technology
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-pulse-subtle">
      <svg class="w-5 h-5" style="color: var(--color-text-tertiary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </div>
  </section>

  <!-- THREE PILLARS -->
  <section class="section-padding" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <div class="mb-14">
        <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
          Platform
        </p>
        <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
          Three systems. One stack.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {pillars.map((p, i) => (
          <a
            href={p.href}
            class={`reveal reveal-delay-${Math.min(i + 1, 4)} card-gradient-border p-7 group cursor-pointer`}
            data-tilt
          >
            <div class="relative z-10">
              <div class="flex items-center gap-3 mb-4">
                <div
                  class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors duration-300"
                  style="background: var(--color-accent-muted); color: var(--color-accent-hover); border: 1px solid var(--color-border);"
                >
                  <Fragment set:html={p.icon} />
                </div>
                <div>
                  <h3 class="text-base font-semibold tracking-tight">{p.name}</h3>
                  <span class="text-[11px]" style="color: var(--color-text-tertiary);">{p.subtitle}</span>
                </div>
              </div>
              <div class="my-4 flex items-baseline gap-2">
                <span class="font-mono text-fluid-xl font-bold" style="color: var(--color-accent);">{p.metric}</span>
                <span class="font-mono text-[11px] tracking-wider uppercase" style="color: var(--color-text-tertiary);">{p.metricLabel}</span>
              </div>
              <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-secondary);">
                {p.description}
              </p>
              <span class="text-[11px] font-medium tracking-wider uppercase" style="color: var(--color-accent);">
                Learn more &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- METRICS BAR -->
  <section class="py-16 md:py-24 overflow-hidden">
    <div class="container-max mx-auto">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 md:gap-0">
        {metrics.map((m, i) => (
          <div class={`text-center reveal reveal-delay-${Math.min(i + 1, 4)} ${i > 0 ? 'md:border-l' : ''}`} style={i > 0 ? 'border-color: var(--color-border-subtle);' : ''}>
            <div class="stat-number text-fluid-2xl" style="color: var(--color-accent);">{m.value}</div>
            <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-2" style="color: var(--color-text-tertiary);">{m.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AGENT CATALOG PREVIEW -->
  <section class="px-6 md:px-12 lg:px-20 py-16 md:py-24" style="background: var(--color-surface-secondary);">
    <div class="container-max mx-auto">
      <div class="flex items-end justify-between mb-10 flex-wrap gap-4">
        <div>
          <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
            Products
          </p>
          <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
            Domain expert AI agents
          </h2>
          <p class="text-sm mt-3 max-w-lg reveal reveal-delay-2" style="color: var(--color-text-secondary);">
            Production-ready agents built by the Agent Factory. Each one stress-tested, calibrated, and deployed with tools, knowledge bases, and evaluation rubrics.
          </p>
        </div>
        <a href="/products" class="btn-outline text-xs uppercase reveal reveal-delay-2">
          View all &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {agents.map((a, i) => (
          <div
            class={`reveal reveal-delay-${Math.min(i + 1, 4)} rounded-xl p-5 transition-all duration-300 hover:scale-[1.02]`}
            style={`background: var(--color-surface-elevated); border: 1px solid var(--color-border); border-left: 3px solid ${a.accent};`}
          >
            <div class="flex items-center justify-between mb-1">
              <h3 class="text-sm font-semibold tracking-tight">{a.name}</h3>
              <span class="font-mono text-[10px] tracking-wider" style="color: var(--color-accent);">{a.tools} tools</span>
            </div>
            <p class="text-[11px] mb-1" style="color: var(--color-text-tertiary);">{a.subtitle}</p>
            <p class="text-[10px]" style="color: var(--color-text-tertiary); opacity: 0.7;">{a.domain}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BACKGROUND -->
  <section class="px-6 md:px-12 lg:px-20 py-16 md:py-24">
    <div class="container-max mx-auto max-w-3xl text-center">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">
        Background
      </p>
      <h2 class="text-fluid-2xl font-semibold tracking-tight mt-3 mb-6 reveal reveal-delay-1">
        Built by one engineer
      </h2>
      <p class="text-fluid-base font-medium tracking-tight mb-4 reveal reveal-delay-2">
        Marine. SIGINT linguist. Software engineer. ML researcher.
      </p>
      <div class="space-y-3 text-sm leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        <p>
          I build defense technology from PyTorch training runs to Go backends
          to React tactical dashboards to LaTeX patent applications.
        </p>
        <p>
          27 provisional patents. 5 ArXiv papers. An autonomous agent factory
          that builds other AI agents. A P2P mesh network. All running on one
          GPU with zero cloud dependency.
        </p>
      </div>

      <div class="divider my-10 reveal reveal-delay-3"></div>

      <div class="grid grid-cols-3 gap-8 reveal reveal-delay-3">
        <div>
          <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">27</div>
          <div class="text-xs mt-1" style="color: var(--color-text-tertiary);">Patents<br/>filed</div>
        </div>
        <div>
          <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">5</div>
          <div class="text-xs mt-1" style="color: var(--color-text-tertiary);">ArXiv<br/>papers</div>
        </div>
        <div>
          <div class="stat-number text-fluid-xl" style="color: var(--color-accent);">$16K</div>
          <div class="text-xs mt-1" style="color: var(--color-text-tertiary);">Total<br/>hardware</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding relative overflow-hidden" style="background: var(--color-surface-secondary);">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full pointer-events-none" style="opacity: 0.07; background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"></div>

    <div class="relative container-max mx-auto max-w-2xl text-center">
      <h2 class="text-fluid-2xl font-semibold tracking-tight reveal">
        Get in touch
      </h2>
      <p class="mt-4 text-sm max-w-md mx-auto leading-relaxed reveal reveal-delay-1" style="color: var(--color-text-secondary);">
        Software licensing, API access, custom AI agents, or enterprise deployment.
      </p>

      <div class="mt-8 reveal reveal-delay-2">
        <a href="mailto:jesse@thornveil.ai" class="btn-primary">
          jesse@thornveil.ai
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </a>
      </div>

      <div class="mt-12 font-mono flex flex-wrap justify-center gap-x-3 gap-y-1 text-[10px] tracking-[0.15em] uppercase reveal reveal-delay-3" style="color: var(--color-text-tertiary);">
        <span>Thornveil LLC</span>
        <span class="opacity-40">&middot;</span>
        <span>Tampa, FL</span>
        <span class="opacity-40">&middot;</span>
        <span>NAICS 541511, 541512</span>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import Lenis from 'lenis';

  const lenis = new Lenis({
    duration: 1.2,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
  });

  function raf(time: number) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector((anchor as HTMLAnchorElement).getAttribute('href')!);
      if (target) lenis.scrollTo(target as HTMLElement);
    });
  });

  document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
    const MAX_DEG = 4;
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;
      card.style.transform = `perspective(800px) rotateX(${(0.5 - y) * MAX_DEG}deg) rotateY(${(x - 0.5) * MAX_DEG}deg)`;
      card.style.transition = 'transform 0.1s ease-out';
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg)';
      card.style.transition = 'transform 0.4s ease-out';
    });
  });
</script>
