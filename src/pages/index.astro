            </div>
            <div>
              <div class="stat-number text-fluid-xl">6</div>
              <div class="text-xs mt-1" style="color: var(--color-text-tertiary);">
                product<br />lines
              </div>
            </div>
          </div>
        </div>

        <!-- Right: track record -->
        <div class="lg:col-span-3 reveal reveal-delay-2">
          <div
            class="rounded-xl overflow-hidden"
            style="border: 1px solid var(--color-border);"
