---

<BaseLayout
  title="Systems | Thornveil"
  description="Ten production-grade systems on github.com/thornveil-ai. Audit-verified codebase metrics, public companion repositories for review, trade-secret-grade IP framing. Built solo while active-duty USMC since January 2026."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-max mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Systems</p>
      <h1 class="text-fluid-3xl font-semibold tracking-tight mt-3 reveal reveal-delay-1">
        Ten production-grade systems. One sovereign AI stack.
      </h1>
      <p class="text-base mt-5 max-w-3xl leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        Each tile below carries audit-verified codebase metrics and a link to the public companion repository for review. Source for the proprietary systems lives behind licensing; the public companions hold marketing-grade documentation, architecture overviews, and API contracts that evaluators can read.
      </p>
      <div class="mt-6 flex flex-wrap gap-3 reveal reveal-delay-3">
        <a href="https://github.com/thornveil-ai" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-sm transition-all" style="background: var(--color-accent); color: #0B0F1A;">
          Browse the org →
        </a>
        <a href="/cofounder" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-sm transition-all" style="background: var(--color-surface-elevated); color: var(--color-text-primary); border: 1px solid var(--color-border);">
          Apply to co-found →
        </a>
      </div>
    </div>
  </section>

  <!-- SYSTEMS GRID -->
  <section class="section-padding pt-12">
    <div class="container-max mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {systems.map((s, i) => (
          <div class={`reveal reveal-delay-${Math.min(i + 1, 4)} card-gradient-border p-7 flex flex-col`} data-tilt>
            <div class="relative z-10 flex flex-col h-full">
              <div class="flex items-start justify-between gap-3 mb-3">
                <div>
                  <h3 class="text-lg font-semibold tracking-tight">{s.name}</h3>
                  <p class="text-xs mt-0.5" style="color: var(--color-text-tertiary);">{s.tagline}</p>
                </div>
                <span class="font-mono text-[9px] tracking-[0.15em] uppercase px-2 py-0.5 rounded-full shrink-0" style="background: var(--color-accent-muted); color: var(--color-accent);">
                  {s.visibility}
                </span>
              </div>
              <div class="my-3 flex items-baseline gap-2">
                <span class="font-mono text-fluid-xl font-bold" style="color: var(--color-accent);">{s.metric}</span>
                <span class="font-mono text-[10px] tracking-wider uppercase" style="color: var(--color-text-tertiary);">{s.metricLabel}</span>
              </div>
              <p class="text-sm leading-relaxed mb-4 flex-1" style="color: var(--color-text-secondary);">
                {s.description}
              </p>
              <div class="pt-3 mt-auto flex flex-wrap items-center justify-between gap-2" style="border-top: 1px solid var(--color-border-subtle);">
                <span class="font-mono text-[10px] tracking-wider uppercase" style="color: var(--color-text-tertiary);">{s.status}</span>
                <div class="flex gap-2 flex-wrap">
                  {s.detail && (
                    <a href={s.detail} class="font-mono text-[10px] tracking-wider uppercase px-2.5 py-1 rounded-full transition-colors hover:opacity-80" style="background: var(--color-accent); color: #0B0F1A;">
                      Deep dive
                    </a>
                  )}
                  {s.overview ? (
                    <a href={s.overview} target="_blank" rel="noopener" class="font-mono text-[10px] tracking-wider uppercase px-2.5 py-1 rounded-full transition-colors hover:opacity-80" style="background: var(--color-surface); color: var(--color-text-secondary); border: 1px solid var(--color-border);">
                      {s.overviewLabel} ↗
                    </a>
                  ) : (
                    <span class="font-mono text-[10px] tracking-wider uppercase px-2.5 py-1 rounded-full" style="background: var(--color-surface); color: var(--color-text-tertiary); border: 1px solid var(--color-border);">
                      Internal-only
                    </span>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BUILD CONTEXT -->
  <section class="section-padding pt-0">
    <div class="container-max mx-auto max-w-3xl text-center">
      <p class="text-[11px] font-semibold tracking-[0.3em] uppercase reveal" style="color: var(--color-accent);">Build context</p>
      <h2 class="text-fluid-xl font-semibold tracking-tight mt-3 mb-6 reveal reveal-delay-1">
        Five months. Solo. Active duty.
      </h2>
      <div class="space-y-4 text-sm leading-relaxed reveal reveal-delay-2" style="color: var(--color-text-secondary);">
        <p>
          First commit on the oldest repo: January 12, 2026. Combined ~1.3M LOC across Go, Rust, Python, TypeScript, and Dart by May 2026. Built solo while active-duty USMC. Direct contracts open December 10, 2026 (DD-214). Soft engagements and co-founder applications open now.
        </p>
        <p>
          See <a href="/about" style="color: var(--color-accent); text-decoration: underline;">about</a> for the founder narrative and <a href="/cofounder" style="color: var(--color-accent); text-decoration: underline;">co-founder</a> for the seat we're looking to fill.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding relative overflow-hidden" style="background: var(--color-surface-secondary);">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full pointer-events-none" style="opacity: 0.07; background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"></div>
    <div class="relative container-max mx-auto max-w-2xl text-center">
      <h2 class="text-fluid-2xl font-semibold tracking-tight reveal">Review the work. Reach out.</h2>
      <p class="mt-4 text-sm max-w-md mx-auto leading-relaxed reveal reveal-delay-1" style="color: var(--color-text-secondary);">
        Federal program offices, defense primes, evaluators, co-founder candidates — direct line.
      </p>
      <div class="mt-8 reveal reveal-delay-2 flex flex-wrap gap-3 justify-center">
        <a href="mailto:jesse@thornveil.ai" class="btn-primary">
          jesse@thornveil.ai
        </a>
        <a href="https://github.com/thornveil-ai" target="_blank" rel="noopener" class="btn-outline">
          github.com/thornveil-ai
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  const lenis = new Lenis({ duration: 1.2, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
  function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);

  document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
    const MAX_DEG = 4;
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;
      card.style.transform = `perspective(800px) rotateX(${(0.5 - y) * MAX_DEG}deg) rotateY(${(x - 0.5) * MAX_DEG}deg)`;
      card.style.transition = 'transform 0.1s ease-out';
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg)';
      card.style.transition = 'transform 0.4s ease-out';
    });
  });
</script>
