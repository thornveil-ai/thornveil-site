---
import BaseLayout from '../layouts/BaseLayout.astro';

// All 10 systems on the org with audit-verified metrics from VALUATION.md deep dives.
const systems = [
  {
    name: 'Signet',
    tagline: 'Capability gates for LLM agents.',
    description: 'A 4-stage check pipeline (ADMISSION / INSPECTION / COMMITMENT / RECORD) with HMAC-chained tamper-evident audit log and RFC 3161 trusted-timestamp anchoring. 11 production checks. The Signet vocabulary that Auspex extends with engagement-specific checks. Apache-2.0 OSS. Available on PyPI as `signet-sign`.',
    metric: '25K + 31K',
    metricLabel: 'source LOC + test LOC',
    status: 'v0.1.10.1 production',
    visibility: 'Public OSS',
    overview: 'https://github.com/thornveil-ai/signet',
    overviewLabel: 'github.com/thornveil-ai/signet',
  },
  {
    name: 'Alchemist',
    tagline: 'Algorithm-aware C-to-Rust translation.',
    description: 'Five correctness gates: compile, anti-stub, no-unsafe, cargo test, differential (10K/10K against C reference). The pipeline refuses to claim success without a differential config. Local LLM only — no cloud paths. Built for the CISA / DoD / ONCD memory-safe regulatory tide.',
    metric: '21K',
    metricLabel: 'Python LOC + 546 tests',
    status: 'Research prototype',
    visibility: 'Public OSS',
    overview: 'https://github.com/thornveil-ai/alchemist',
    overviewLabel: 'github.com/thornveil-ai/alchemist',
  },
  {
    name: 'Pyros',
    tagline: 'Self-sustaining inference engine.',
    description: '24 adaptive subsystems organized into 7 conceptual pillars. PID homeostasis + Holt forecaster + UCB1 bandit + epsilon-greedy variant evolution wired into one orchestrator. PAVA isotonic regression calibrator validated against sklearn. Race-clean across Linux/macOS/Windows. Backend-agnostic — wraps Ollama, vLLM, llama.cpp, LMStudio.',
    metric: '17K',
    metricLabel: 'Go LOC, race-clean',
    status: 'v0.2.1 — used inside RigRun + Mycelium',
    visibility: 'Private; public companion',
    overview: 'https://github.com/thornveil-ai/pyros-overview',
    overviewLabel: 'github.com/thornveil-ai/pyros-overview',
  },
  {
    name: 'Mycelium',
    tagline: 'Distributed AI mesh. Substitute-on-failure inference.',
    description: 'Six workers pool compute for one Gemma-4-26B chat. When workers drop, substitute-on-failure dispatch keeps generation continuing — Day-27 cryptographic reduction-to-practice. R2I-aligned MOSA surface with 50-endpoint OpenAPI 3.1 published. 38 of 42 in-scope NIST 800-53 controls implemented with file-path traceability. mTLS on worker channel, HMAC-chained per-request audit log.',
    metric: '250K + 19K',
    metricLabel: 'Go + Python LOC',
    status: 'v1.0.0 — customer engagement in motion',
    visibility: 'Private; public companion',
    overview: 'https://github.com/thornveil-ai/mycelium-overview',
    overviewLabel: 'github.com/thornveil-ai/mycelium-overview',
    detail: '/mycelium',
  },
  {
    name: 'RigRun',
    tagline: 'Professional AI chat. Classification-gated routing.',
    description: 'Three apps (desktop, mobile, web) on one Go backend. Classification gate enforced at the type-system level — CUI+ queries hard-blocked from cloud routing as architectural narrowing, not runtime policy. 44 NIST 800-53 controls implemented as discrete code paths. 8-signal confidence pipeline. IR-9 spillage detection with Unicode normalization + entropy thresholding.',
    metric: '496K',
    metricLabel: 'LOC, 6,950 tests',
    status: 'v0.9 — federal evaluation post-DD-214',
    visibility: 'Private; public companion',
    overview: 'https://github.com/thornveil-ai/rigrun-overview',
    overviewLabel: 'github.com/thornveil-ai/rigrun-overview',
  },
  {
    name: 'HawkStack',
    tagline: 'Compute-aware neural-architecture topology.',
    description: 'Topology-driven recipe that turns (dataset, domain) into (architecture, training config) and produces sub-million-parameter models that match SOTA in their weight class. 15 verified zoo checkpoints across IRST (synthetic + real), sonar, PCB defect, histopathology, thermal drone, and ECG. 16-run power-law scaling fit on NUDT-SIRST (R²=0.9895). 26-page topology paper preparing arXiv submission.',
    metric: '15',
    metricLabel: 'zoo checkpoints, 6 domains',
    status: 'v0.3.0 — paper preparing arXiv',
    visibility: 'Private; public research companion',
    overview: 'https://github.com/thornveil-ai/hawkstack-paper',
    overviewLabel: 'github.com/thornveil-ai/hawkstack-paper',
  },
  {
    name: 'Meridian',
    tagline: 'Memory-safe Rust flight-control firmware.',
    description: 'From-scratch ArduPilot/PX4 alternative on STM32 H7 / F4 / F7. Phase 10 trade-secret primitives no other autopilot ships: ed25519-signed airworthiness attestation, RC hijack / GPS spoof / mag jam adversarial-detection failsafes, Find My Drone beacon, self-learning vehicle dynamics ID, Black Box event taxonomy. 47K lines of parity-audit notes against 154 ArduPilot libraries. Hardware bring-up active on MatekH743 and Cube Orange Plus.',
    metric: '98K Rust + 60',
    metricLabel: 'LOC + crates',
    status: 'Hardware bring-up active',
    visibility: 'Private; OSS predecessor public',
    overview: 'https://github.com/thornveil-ai/meridian-core',
    overviewLabel: 'github.com/thornveil-ai/meridian-core',
  },
  {
    name: 'Canopy',
    tagline: 'Multi-modal counter-UAS situational awareness.',
    description: 'RF + acoustic + thermal + Remote ID + ADS-B fusion. Real Kalman tracking + Dempster-Shafer evidence fusion + bearing-intersection geolocation (tested). Mesh networking + decision engine scaffolded but not yet wired. Honest Phase 0 framing — designed to replace DragonOS/WarDragon with mesh-aware open architecture. Hardware tiers from $270 (Pi 5 + RTL-SDR) to $1,650 (KrakenSDR + UCA DF).',
    metric: 'Phase 0',
    metricLabel: 'architecture validated',
    status: 'Phase 0 — integration pending',
    visibility: 'Private; public preview',
    overview: 'https://github.com/thornveil-ai/canopy-preview',
    overviewLabel: 'github.com/thornveil-ai/canopy-preview',
  },
  {
    name: 'Auspex',
    tagline: 'AI red team gated by Signet. Federal-only.',
    description: 'The model proposes. Signet authorizes. Auspex executes only what is allowed. Scope-as-code engagement compilation. 13 standard authority checks at the Signet gate. HMAC-chained per-engagement audit log with RFC 3161 trusted-timestamp anchoring. Validated end-to-end on adversarial Active Directory takeover with auditable replay package. Federal-gated, EAR ECCN 4D004.',
    metric: '66K Go + 5K',
    metricLabel: 'LOC + Python SFT',
    status: 'v0.6.0-rc1 Federal Edition',
    visibility: 'Federal-gated; contact-only public',
    overview: 'https://github.com/thornveil-ai/auspex-contact',
    overviewLabel: 'github.com/thornveil-ai/auspex-contact',
  },
  {
    name: 'Navigator',
    tagline: 'AI ops center. Agent Factory.',
    description: 'Internal AI ops infrastructure. The Agent Factory is a 14-step pipeline (decompose → multi-pass system prompt → tool selection → Opus calibration → 5-probe adversarial stress test → adversarial hardening → functional tests → quality gate) that produces production domain-expert agents. 9 production agents shipped including OPORD Drafter (FM 6-0 / JP 5-0 / ADP 5-0 compliant), SBIR Writer, Security Auditor, Research Scout. 80 MCP-exposed tools across 9 domains.',
    metric: '40K + 9',
    metricLabel: 'LOC + production agents',
    status: 'Internal — Federal Agent Pack candidate',
    visibility: 'Internal-only; no public companion',
    overview: null,
    overviewLabel: null,
  },
