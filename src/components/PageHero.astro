---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="relative pt-32 pb-20 md:pt-40 md:pb-28">
  <!-- Subtle gradient background -->
  <div class="absolute inset-0 bg-gradient-to-b from-navy-dark via-navy to-navy opacity-80"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(74,110,125,0.08)_0%,_transparent_60%)]"></div>

  <div class="relative container-max mx-auto px-6 md:px-12 lg:px-20">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-6 text-lg md:text-xl text-white/50 max-w-2xl leading-relaxed">
        {subtitle}
      </p>
    )}
    <!-- Accent line -->
    <div class="mt-8 w-16 h-0.5 bg-teal"></div>
  </div>
</section>
