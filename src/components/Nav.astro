---
const navLinks = [
  { href: '/capabilities', label: 'Capabilities' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="container-max mx-auto px-6 md:px-12 lg:px-20 flex items-center justify-between h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/logo-horizontal-white.png"
        alt="Thornveil"
        class="h-8 md:h-10 w-auto opacity-90 group-hover:opacity-100 transition-opacity"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-10">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium tracking-wider uppercase text-white/70 hover:text-white transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Toggle navigation"
    >
      <span class="block w-6 h-0.5 bg-white/80 transition-all duration-300 origin-center" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-white/80 transition-all duration-300" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-white/80 transition-all duration-300 origin-center" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden max-h-0 transition-all duration-500 bg-navy-dark/98 backdrop-blur-lg"
  >
    <div class="px-6 py-6 flex flex-col gap-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-base font-medium tracking-wider uppercase text-white/70 hover:text-white transition-colors py-2 border-b border-white/5"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  // Scroll-based nav background
  const nav = document.getElementById('nav');
  const onScroll = () => {
    if (window.scrollY > 80) {
      nav?.classList.add('bg-navy-dark/95', 'backdrop-blur-lg', 'shadow-lg', 'shadow-black/20');
    } else {
      nav?.classList.remove('bg-navy-dark/95', 'backdrop-blur-lg', 'shadow-lg', 'shadow-black/20');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile toggle
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    if (open) {
      menu!.style.maxHeight = menu!.scrollHeight + 'px';
      bar1?.classList.add('rotate-45', 'translate-y-[4px]');
      bar2?.classList.add('opacity-0');
      bar3?.classList.add('-rotate-45', '-translate-y-[4px]');
    } else {
      menu!.style.maxHeight = '0';
      bar1?.classList.remove('rotate-45', 'translate-y-[4px]');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-rotate-45', '-translate-y-[4px]');
    }
  });
</script>
