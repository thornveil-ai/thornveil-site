---
const navLinks = [
  { href: '/products', label: 'Products' },
  { href: '/technology', label: 'Technology' },
  { href: '/defense', label: 'Defense' },
  { href: '/research', label: 'Research' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <nav class="container-max mx-auto px-6 md:px-12 lg:px-20 flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex items-center relative h-16 md:h-20">
      <img
        src="/logo-horizontal-white.png"
        alt="Thornveil"
        class="logo-dark h-16 md:h-20 w-auto transition-opacity duration-300"
      />
      <img
        src="/logo-horizontal.png"
        alt="Thornveil"
        class="logo-light h-16 md:h-20 w-auto absolute left-0 top-0 opacity-0 transition-opacity duration-300"
      />
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`nav-link text-[11px] font-medium tracking-[0.15em] uppercase transition-colors duration-300 ${
            currentPath === link.href || (currentPath.startsWith(link.href) && link.href !== '/')
              ? 'nav-active'
              : ''
          }`}
          style={
            currentPath === link.href || (currentPath.startsWith(link.href) && link.href !== '/')
              ? 'color: var(--color-accent);'
              : 'color: var(--color-text-tertiary);'
          }
        >
          {link.label}
        </a>
      ))}

      <button
        id="theme-toggle"
        class="relative w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-300"
        style="color: var(--color-text-tertiary);"
        aria-label="Toggle theme"
        title="Toggle theme"
      >
        <svg class="theme-icon-sun w-4 h-4 absolute transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg class="theme-icon-moon w-4 h-4 absolute transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>
    </div>

    <div class="flex md:hidden items-center gap-3">
      <button
        id="theme-toggle-mobile"
        class="w-8 h-8 rounded-lg flex items-center justify-center relative transition-colors"
        style="color: var(--color-text-tertiary);"
        aria-label="Toggle theme"
      >
        <svg class="theme-icon-sun w-4 h-4 absolute transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg class="theme-icon-moon w-4 h-4 absolute transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>

      <button
        id="mobile-toggle"
        class="flex flex-col gap-1.5 p-2"
        aria-label="Toggle navigation"
      >
        <span class="block w-5 h-px transition-all duration-300 origin-center" style="background: var(--color-text-tertiary);" id="bar1"></span>
        <span class="block w-5 h-px transition-all duration-300" style="background: var(--color-text-tertiary);" id="bar2"></span>
        <span class="block w-5 h-px transition-all duration-300 origin-center" style="background: var(--color-text-tertiary);" id="bar3"></span>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden max-h-0 transition-all duration-500"
    style="background: var(--glass-bg); backdrop-filter: blur(var(--glass-blur));"
  >
    <div class="px-6 py-4 flex flex-col gap-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium tracking-[0.15em] uppercase transition-colors py-2"
          style={
            currentPath === link.href
              ? 'color: var(--color-accent);'
              : 'color: var(--color-text-secondary);'
          }
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('nav');
  const onScroll = () => {
    if (window.scrollY > 50) {
      nav?.classList.add('glass-nav');
    } else {
      nav?.classList.remove('glass-nav');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  function updateThemeIcons() {
    const isLight = document.documentElement.classList.contains('light');
    document.querySelectorAll('.theme-icon-sun').forEach(el => {
      (el as HTMLElement).style.opacity = isLight ? '0' : '1';
      (el as HTMLElement).style.transform = isLight ? 'rotate(-90deg) scale(0)' : 'rotate(0) scale(1)';
    });
    document.querySelectorAll('.theme-icon-moon').forEach(el => {
      (el as HTMLElement).style.opacity = isLight ? '1' : '0';
      (el as HTMLElement).style.transform = isLight ? 'rotate(0) scale(1)' : 'rotate(90deg) scale(0)';
    });
    document.querySelectorAll('.logo-dark').forEach(el => {
      (el as HTMLElement).style.opacity = isLight ? '0' : '1';
    });
    document.querySelectorAll('.logo-light').forEach(el => {
      (el as HTMLElement).style.opacity = isLight ? '1' : '0';
    });
  }

  function toggleTheme() {
    const isCurrentlyLight = document.documentElement.classList.contains('light');
    if (isCurrentlyLight) {
      document.documentElement.classList.remove('light');
      localStorage.setItem('theme', 'dark');
    } else {
      document.documentElement.classList.add('light');
      localStorage.setItem('theme', 'light');
    }
    updateThemeIcons();
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
  updateThemeIcons();

  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    if (open) {
      menu!.style.maxHeight = menu!.scrollHeight + 'px';
      bar1?.classList.add('rotate-45', 'translate-y-[3px]');
      bar2?.classList.add('opacity-0');
      bar3?.classList.add('-rotate-45', '-translate-y-[3px]');
    } else {
      menu!.style.maxHeight = '0';
      bar1?.classList.remove('rotate-45', 'translate-y-[3px]');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-rotate-45', '-translate-y-[3px]');
    }
  });

  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      open = false;
      menu!.style.maxHeight = '0';
      bar1?.classList.remove('rotate-45', 'translate-y-[3px]');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-rotate-45', '-translate-y-[3px]');
    });
  });
</script>
