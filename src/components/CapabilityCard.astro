---
interface Props {
  title: string;
  description: string;
  icon: string;
  delay?: number;
}

const { title, description, icon, delay = 0 } = Astro.props;
---

<div class={`reveal reveal-delay-${delay} group card-glow rounded-lg bg-white/[0.02] border border-white/5 p-8 md:p-10 hover:bg-white/[0.04] transition-all duration-500`}>
  <!-- Icon -->
  <div class="w-12 h-12 rounded-lg bg-teal/10 border border-teal/20 flex items-center justify-center mb-6 group-hover:bg-teal/20 transition-colors duration-500">
    <Fragment set:html={icon} />
  </div>

  <h3 class="text-xl font-semibold tracking-tight mb-3">{title}</h3>
  <p class="text-white/50 leading-relaxed text-sm">{description}</p>
</div>
